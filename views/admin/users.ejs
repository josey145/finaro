<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Finora Bank</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --primary: #0F6E56;
            --accent: #1D9E75;
            --bg-body: #F4F8F7;
            --white: #FFFFFF;
            --text-main: #0D1B16;
            --text-muted: #64748B;
            --border: #E8EFED;
            --danger: #ef4444;
            --success: #22c55e;
            --warning: #f59e0b;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            padding-bottom: 90px;
        }

        .main-content { padding: 20px; max-width: 1200px; margin: 0 auto; }

        .flash-message {
            padding: 14px 18px; border-radius: 12px; margin-bottom: 20px;
            font-size: 14px; display: flex; align-items: center; gap: 10px;
        }
        .flash-danger  { background: #fef2f2; color: var(--danger);  border: 1px solid #fecaca; }
        .flash-success { background: #f0fdf4; color: var(--success); border: 1px solid #bbf7d0; }

        /* HERO */
        .balance-card {
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            border-radius: 24px; padding: 32px; color: white;
            margin-bottom: 24px;
            box-shadow: 0 15px 35px rgba(15, 110, 86, 0.3);
        }
        .balance-label { font-size: 14px; opacity: 0.9; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
        .balance-amount { font-size: 2.2rem; font-weight: 800; margin-bottom: 20px; letter-spacing: -1px; }

        .action-buttons { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
        .action-btn {
            background: rgba(255,255,255,0.15); backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.2); border-radius: 16px;
            padding: 16px 8px; color: white; text-decoration: none;
            text-align: center; transition: all 0.3s;
            display: flex; flex-direction: column; align-items: center; gap: 8px;
        }
        .action-btn:hover { background: rgba(255,255,255,0.25); transform: translateY(-3px); color: white; }
        .action-btn i {
            font-size: 22px; width: 46px; height: 46px;
            background: rgba(255,255,255,0.2); border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
        }
        .action-btn span { font-size: 12px; font-weight: 600; }

        /* CARD */
        .f-card {
            background: var(--white); border-radius: 24px; padding: 24px;
            border: 1px solid var(--border);
            box-shadow: 0 10px 30px -5px rgba(15, 110, 86, 0.05);
        }

        /* SEARCH */
        .search-input {
            background: var(--bg-body); border: 1px solid var(--border);
            border-radius: 14px; padding: 12px 18px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 14px; outline: none; transition: border-color 0.2s;
        }
        .search-input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(15,110,86,0.1); }

        /* USER ROW */
        .user-row {
            display: flex; align-items: center; justify-content: space-between;
            padding: 14px 16px; background: var(--bg-body);
            border-radius: 16px; margin-bottom: 10px;
            border: 1px solid var(--border); transition: all 0.2s;
        }
        .user-row:hover { border-color: var(--primary); box-shadow: 0 4px 12px rgba(15,110,86,0.08); }

        .user-avatar {
            width: 46px; height: 46px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-weight: 800; font-size: 16px; color: white;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            flex-shrink: 0;
        }
        .user-avatar.suspended {
            background: linear-gradient(135deg, #94a3b8, #64748b);
        }

        /* BADGES */
        .status-badge {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 5px 12px; border-radius: 20px;
            font-size: 11px; font-weight: 700;
        }
        .badge-active   { background: #f0fdf4; color: var(--success); }
        .badge-suspended{ background: #fef2f2; color: var(--danger);  }
        .badge-kyc-ok   { background: #f0fdf4; color: var(--success); }
        .badge-kyc-pend { background: #fffbeb; color: var(--warning); }
        .badge-kyc-no   { background: #fef2f2; color: var(--danger);  }

        /* ACTION BTNS */
        .btn-icon {
            width: 34px; height: 34px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            border: 1px solid var(--border); background: var(--white);
            cursor: pointer; transition: all 0.2s; font-size: 13px;
            text-decoration: none;
        }
        .btn-icon:hover { transform: translateY(-2px); }
        .btn-icon.suspend  { color: var(--warning); }
        .btn-icon.suspend:hover  { background: #fffbeb; border-color: var(--warning); }
        .btn-icon.unsuspend { color: var(--success); }
        .btn-icon.unsuspend:hover { background: #f0fdf4; border-color: var(--success); }
        .btn-icon.delete   { color: var(--danger); }
        .btn-icon.delete:hover   { background: #fef2f2; border-color: var(--danger); }
        .btn-icon.fund     { color: var(--primary); }
        .btn-icon.fund:hover     { background: #f0fdf4; border-color: var(--primary); }
        .btn-icon.view     { color: var(--text-muted); }
        .btn-icon.view:hover     { background: var(--bg-body); }

        /* MODAL */
        .modal-content { border-radius: 24px; border: none; }
        .modal-header  { border-bottom: 1px solid var(--border); padding: 20px 24px; }
        .modal-body    { padding: 24px; }
        .modal-footer  { border-top: 1px solid var(--border); padding: 16px 24px; }
        .form-label    { font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px; }
        .form-control  {
            border-radius: 14px; border: 1px solid var(--border);
            padding: 12px 16px; font-family: 'Plus Jakarta Sans', sans-serif;
        }
        .form-control:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(15,110,86,0.1); }
        .form-select {
            border-radius: 14px; border: 1px solid var(--border);
            padding: 12px 16px; font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .btn-primary-custom {
            background: linear-gradient(135deg, var(--primary), var(--accent));
            color: white; border: none; padding: 12px 24px;
            border-radius: 14px; font-weight: 700; cursor: pointer;
        }
        .btn-danger-custom {
            background: var(--danger); color: white; border: none;
            padding: 12px 24px; border-radius: 14px; font-weight: 700; cursor: pointer;
        }

        /* EMPTY STATE */
        .empty-state { text-align: center; padding: 50px 20px; color: var(--text-muted); }

        /* MOBILE NAV */
        .mobile-nav {
            position: fixed; bottom: 0; left: 0; width: 100%;
            background: rgba(255,255,255,0.95); backdrop-filter: blur(10px);
            border-top: 1px solid var(--border);
            display: flex; justify-content: space-around;
            padding: 10px 0 25px 0; z-index: 1000;
        }
        .nav-item { text-align: center; color: var(--text-muted); text-decoration: none; font-size: 10px; font-weight: 700; }
        .nav-item.active { color: var(--primary); }
        .nav-item i { font-size: 20px; margin-bottom: 4px; display: block; }

        @media (max-width: 768px) {
            .user-meta { display: none; }
            .action-buttons { grid-template-columns: repeat(4,1fr); gap: 8px; }
        }
        @media (min-width: 992px) {
            .main-content { padding: 40px; }
            .mobile-nav { display: none; }
            body { padding-bottom: 0; }
        }
    </style>
</head>
<body>

<div class="main-content">

    <!-- Flash -->
    <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
        <div class="flash-message flash-success"><i class="fas fa-circle-check"></i> <%= success_msg %></div>
    <% } %>
    <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
        <div class="flash-message flash-danger"><i class="fas fa-circle-exclamation"></i> <%= error_msg %></div>
    <% } %>

    <!-- Header -->
    <header class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="small text-muted mb-0">
                <a href="/admin/dashboard" class="text-decoration-none" style="color:var(--primary);">
                    <i class="fa-solid fa-arrow-left me-1"></i> Dashboard
                </a>
            </p>
            <h1 class="h4 fw-bold mb-0">Manage Users</h1>
        </div>
        <a href="/auth/logout" class="bg-white p-2 rounded-3 border text-decoration-none">
            <i class="fa-solid fa-right-from-bracket text-danger"></i>
        </a>
    </header>

    <!-- HERO -->
    <div class="balance-card">
        <div class="balance-label">Total Users</div>
        <div class="balance-amount">
            <i class="fa-solid fa-users me-2" style="opacity:0.8;"></i>
            <%= (typeof users !== 'undefined' && users) ? users.length : 0 %> Accounts
        </div>
        <div class="action-buttons">
            <a href="/admin/users/create" class="action-btn">
                <i class="fa-solid fa-user-plus"></i>
                <span>New User</span>
            </a>
            <a href="/admin/fund" class="action-btn">
                <i class="fa-solid fa-wallet"></i>
                <span>Fund</span>
            </a>
            <a href="/admin/kyc" class="action-btn">
                <i class="fa-solid fa-id-card"></i>
                <span>KYC</span>
            </a>
            <a href="/admin/dashboard" class="action-btn">
                <i class="fa-solid fa-chart-pie"></i>
                <span>Stats</span>
            </a>
        </div>
    </div>

    <!-- USERS LIST -->
    <div class="f-card">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <h6 class="fw-bold mb-0">All Users</h6>
            <input type="text" class="search-input" id="userSearch"
                   placeholder="🔍  Search name or email..." onkeyup="filterUsers()"
                   style="width: 260px;">
        </div>

        <div id="userList">
        <% if (typeof users !== 'undefined' && users && users.length > 0) { %>
            <% users.forEach(u => { %>
                <div class="user-row"
                     data-name="<%= (u.first_name + ' ' + u.last_name).toLowerCase() %>"
                     data-email="<%= u.email.toLowerCase() %>">

                    <!-- Left: Avatar + Info -->
                    <div class="d-flex align-items-center gap-3">
                        <div class="user-avatar <%= u.is_suspended ? 'suspended' : '' %>">
                            <%= u.first_name ? u.first_name[0].toUpperCase() : 'U' %>
                        </div>
                        <div>
                            <div class="fw-bold small"><%= u.first_name %> <%= u.last_name %></div>
                            <div class="small text-muted"><%= u.email %></div>
                            <div class="small text-muted user-meta">
                                📞 <%= u.phone || 'N/A' %> &nbsp;·&nbsp;
                                Joined <%= new Date(u.created_at).toLocaleDateString() %>
                            </div>
                        </div>
                    </div>

                    <!-- Middle: Balance + KYC (hidden on mobile) -->
                    <div class="d-none d-md-flex flex-column align-items-center gap-1">
                        <div class="fw-bold small" style="color:var(--primary);">
                            $<%= parseFloat(u.balance || 0).toLocaleString(undefined, {minimumFractionDigits:2}) %>
                        </div>
                        <div class="small text-muted" style="font-size:10px;">
                            Acc: <%= u.account_number || 'N/A' %>
                        </div>
                    </div>

                    <!-- Status Badges -->
                    <div class="d-none d-lg-flex flex-column gap-1 align-items-center">
                        <% if (u.is_suspended) { %>
                            <span class="status-badge badge-suspended">
                                <i class="fa-solid fa-ban"></i> Suspended
                            </span>
                        <% } else { %>
                            <span class="status-badge badge-active">
                                <i class="fa-solid fa-circle"></i> Active
                            </span>
                        <% } %>
                        <% if (u.kyc_status === 'approved') { %>
                            <span class="status-badge badge-kyc-ok">
                                <i class="fa-solid fa-circle-check"></i> KYC
                            </span>
                        <% } else if (u.kyc_status === 'pending') { %>
                            <span class="status-badge badge-kyc-pend">
                                <i class="fa-solid fa-clock"></i> KYC Pending
                            </span>
                        <% } else { %>
                            <span class="status-badge badge-kyc-no">
                                <i class="fa-solid fa-xmark"></i> No KYC
                            </span>
                        <% } %>
                    </div>

                    <!-- Actions -->
                    <div class="d-flex gap-2">
                        <button class="btn-icon fund" title="Fund / Deduct"
                                onclick="window.location.href='/admin/fund'">
                            <i class="fa-solid fa-wallet"></i>
                        </button>

                        <% if (u.is_suspended) { %>
                            <button class="btn-icon unsuspend" title="Unsuspend"
                                    onclick="toggleSuspend(<%= u.id %>, 'unsuspend')">
                                <i class="fa-solid fa-lock-open"></i>
                            </button>
                        <% } else { %>
                            <button class="btn-icon suspend" title="Suspend"
                                    onclick="toggleSuspend(<%= u.id %>, 'suspend')">
                                <i class="fa-solid fa-ban"></i>
                            </button>
                        <% } %>

                        <button class="btn-icon delete" title="Delete User"
                                onclick="deleteUser(<%= u.id %>, '<%= u.first_name %> <%= u.last_name %>')">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="empty-state">
                <i class="fa-solid fa-users fs-1 mb-3"></i>
                <h5 class="fw-bold">No Users Yet</h5>
                <p class="text-muted mb-4">Start by creating a new user account.</p>
                <a href="/admin/users/create" class="btn fw-bold rounded-4 px-4"
                   style="background:var(--primary); color:white;">
                    <i class="fa-solid fa-user-plus me-2"></i> Create User
                </a>
            </div>
        <% } %>
        </div>
    </div>
</div>

<!-- Mobile Nav -->
<nav class="mobile-nav">
    <a href="/admin/dashboard" class="nav-item">
        <i class="fa-solid fa-house-chimney"></i> Home
    </a>
    <a href="/admin/users" class="nav-item active">
        <i class="fa-solid fa-users"></i> Users
    </a>
    <a href="/admin/kyc" class="nav-item">
        <i class="fa-solid fa-id-card"></i> KYC
    </a>
    <a href="/admin/settings" class="nav-item">
        <i class="fa-solid fa-gear"></i> Settings
    </a>
</nav>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function filterUsers() {
        const q = document.getElementById('userSearch').value.toLowerCase();
        document.querySelectorAll('.user-row').forEach(row => {
            const name  = row.dataset.name  || '';
            const email = row.dataset.email || '';
            row.style.display = (name.includes(q) || email.includes(q)) ? 'flex' : 'none';
        });
    }

    async function toggleSuspend(userId, action) {
        const msg = action === 'suspend' ? 'Suspend this user?' : 'Unsuspend this user?';
        if (!confirm(msg)) return;
        try {
            const res = await fetch(`/admin/users/${userId}/suspend`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action })
            });
            const data = await res.json();
            if (data.success) {
                showToast(`User ${action}ed successfully`, 'success');
                setTimeout(() => location.reload(), 1200);
            } else {
                showToast('Action failed', 'danger');
            }
        } catch (err) {
            showToast('Something went wrong', 'danger');
        }
    }

    async function deleteUser(userId, name) {
        if (!confirm(`Permanently delete ${name}? This cannot be undone.`)) return;
        try {
            const res = await fetch(`/admin/users/${userId}`, { method: 'DELETE' });
            const data = await res.json();
            if (data.success) {
                showToast('User deleted', 'danger');
                setTimeout(() => location.reload(), 1200);
            } else {
                showToast('Delete failed', 'danger');
            }
        } catch (err) {
            showToast('Something went wrong', 'danger');
        }
    }

    function showToast(message, type) {
        const toast = document.createElement('div');
        toast.style.cssText = `
            position: fixed; top: 20px; right: 20px; z-index: 9999;
            padding: 14px 20px; border-radius: 14px; font-weight: 600;
            font-family: 'Plus Jakarta Sans', sans-serif; font-size: 14px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
            background: ${type === 'success' ? '#f0fdf4' : '#fef2f2'};
            color: ${type === 'success' ? '#22c55e' : '#ef4444'};
            border: 1px solid ${type === 'success' ? '#bbf7d0' : '#fecaca'};
            display: flex; align-items: center; gap: 8px;
        `;
        toast.innerHTML = `<i class="fas fa-${type === 'success' ? 'circle-check' : 'circle-xmark'}"></i> ${message}`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }
</script>
</body>
</html>
