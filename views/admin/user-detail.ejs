<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Finora Bank</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #0F6E56;
      --accent:  #1D9E75;
      --bg-body: #F4F8F7;
      --white:   #FFFFFF;
      --text-main:  #0D1B16;
      --text-muted: #64748B;
      --border:  #E8EFED;
      --danger:  #ef4444;
      --success: #22c55e;
      --warning: #f59e0b;
      --info:    #3b82f6;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    body {
      font-family:'Plus Jakarta Sans',sans-serif;
      background:var(--bg-body);
      color:var(--text-main);
      padding-bottom:90px;
    }
    .main-content { padding:20px; max-width:1200px; margin:0 auto; }

    /* FLASH */
    .flash-message {
      padding:14px 18px; border-radius:12px; margin-bottom:20px;
      font-size:14px; display:flex; align-items:center; gap:10px;
    }
    .flash-danger  { background:#fef2f2; color:var(--danger);  border:1px solid #fecaca; }
    .flash-success { background:#f0fdf4; color:var(--success); border:1px solid #bbf7d0; }

    /* HERO */
    .balance-card {
      background:linear-gradient(135deg,var(--primary) 0%,var(--accent) 100%);
      border-radius:24px; padding:28px 32px; color:white;
      margin-bottom:28px;
      box-shadow:0 15px 35px rgba(15,110,86,.3);
      display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px;
    }
    .balance-label { font-size:13px; opacity:.85; text-transform:uppercase; letter-spacing:1.2px; margin-bottom:6px; }
    .balance-title { font-size:1.8rem; font-weight:800; letter-spacing:-.5px; }
    .hero-icon {
      width:56px; height:56px; border-radius:16px;
      background:rgba(255,255,255,.2);
      display:flex; align-items:center; justify-content:center;
      font-size:22px; color:white;
    }

    /* CARD */
    .f-card {
      background:var(--white); border-radius:24px; padding:28px;
      border:1px solid var(--border);
      box-shadow:0 10px 30px -5px rgba(15,110,86,.06);
      margin-bottom:20px;
    }
    .f-card h6 {
      font-size:15px; font-weight:700; margin-bottom:20px;
      color:var(--text-main); display:flex; align-items:center; gap:10px;
    }
    .section-icon {
      width:32px; height:32px; border-radius:10px;
      background:linear-gradient(135deg,var(--primary),var(--accent));
      display:flex; align-items:center; justify-content:center;
      color:white; font-size:13px; flex-shrink:0;
    }

    /* PROFILE HEADER */
    .profile-header {
      display:flex; align-items:center; gap:16px; margin-bottom:24px;
    }
    .profile-avatar {
      width:72px; height:72px; border-radius:20px;
      background:linear-gradient(135deg,var(--primary),var(--accent));
      display:flex; align-items:center; justify-content:center;
      color:white; font-size:28px; font-weight:800;
      flex-shrink:0;
    }
    .profile-info h2 { font-size:1.3rem; font-weight:800; margin-bottom:4px; }
    .profile-info p { font-size:13px; color:var(--text-muted); }
    
    /* STATUS BADGES */
    .status-badge {
      display:inline-flex; align-items:center; gap:6px;
      padding:5px 12px; border-radius:20px;
      font-size:12px; font-weight:600;
    }
    .badge-success { background:#f0fdf4; color:var(--success); }
    .badge-warning { background:#fffbeb; color:var(--warning); }
    .badge-danger  { background:#fef2f2; color:var(--danger); }
    .badge-info    { background:#eff6ff; color:var(--info); }

    /* INFO GRID */
    .info-grid {
      display:grid; grid-template-columns:1fr; gap:12px;
    }
    @media(min-width:768px) {
      .info-grid { grid-template-columns:1fr 1fr; }
    }
    .info-item {
      padding:14px 16px; background:var(--bg-body);
      border-radius:14px; border:1px solid var(--border);
    }
    .info-label { font-size:11px; color:var(--text-muted); text-transform:uppercase; letter-spacing:.8px; margin-bottom:4px; }
    .info-value { font-size:14px; font-weight:700; color:var(--text-main); }

    /* TABLE */
    .f-table { width:100%; border-collapse:separate; border-spacing:0; }
    .f-table th {
      text-align:left; padding:12px 16px; font-size:11px;
      text-transform:uppercase; letter-spacing:.8px;
      color:var(--text-muted); font-weight:700;
      border-bottom:2px solid var(--border);
    }
    .f-table td {
      padding:14px 16px; font-size:13px;
      border-bottom:1px solid var(--border);
    }
    .f-table tr:last-child td { border-bottom:none; }
    .tx-type { font-weight:600; }
    .tx-credit { color:var(--success); }
    .tx-debit  { color:var(--danger); }
    .tx-amount { font-weight:700; }

    /* ACTION BUTTONS */
    .action-bar {
      display:flex; gap:10px; flex-wrap:wrap; margin-bottom:20px;
    }
    .btn {
      padding:10px 18px; border-radius:12px; font-family:'Plus Jakarta Sans',sans-serif;
      font-size:13px; font-weight:700; cursor:pointer; border:none;
      display:flex; align-items:center; gap:8px; transition:all .2s;
      text-decoration:none;
    }
    .btn-primary { background:linear-gradient(135deg,var(--primary),var(--accent)); color:white; }
    .btn-danger  { background:#fef2f2; color:var(--danger); border:1.5px solid #fecaca; }
    .btn-warning { background:#fffbeb; color:var(--warning); border:1.5px solid #fde68a; }
    .btn:hover { transform:translateY(-1px); }

    /* EMPTY STATE */
    .empty-state { text-align:center; padding:40px 20px; color:var(--text-muted); }
    .empty-state i { font-size:40px; margin-bottom:12px; opacity:.5; }

    /* MOBILE NAV */
    .mobile-nav {
      position:fixed; bottom:0; left:0; width:100%;
      background:rgba(255,255,255,.95); backdrop-filter:blur(10px);
      border-top:1px solid var(--border);
      display:flex; justify-content:space-around;
      padding:10px 0 25px; z-index:1000;
    }
    .nav-item { text-align:center; color:var(--text-muted); text-decoration:none; font-size:10px; font-weight:700; }
    .nav-item.active { color:var(--primary); }
    .nav-item i { font-size:20px; margin-bottom:4px; display:block; }

    /* GRID */
    #main-grid { display:grid; grid-template-columns:1fr; gap:20px; }
    @media(min-width:992px) {
      .main-content { padding:40px; }
      .mobile-nav { display:none; }
      body { padding-bottom:0; }
      #main-grid { grid-template-columns:1fr 360px; }
    }
  </style>
</head>
<body>

<div class="main-content">

  <!-- Flash Messages -->
  <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
    <div class="flash-message flash-success">
      <i class="fas fa-circle-check"></i> <%= success_msg %>
    </div>
  <% } %>
  <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
    <div class="flash-message flash-danger">
      <i class="fas fa-circle-exclamation"></i> <%= error_msg %>
    </div>
  <% } %>

  <!-- Header -->
  <header style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
    <div>
      <p style="font-size:12px;color:var(--text-muted);margin-bottom:2px;">Admin Panel</p>
      <h1 style="font-size:1.2rem;font-weight:800;margin:0;display:flex;align-items:center;gap:8px;">
        <i class="fa-solid fa-shield-halved" style="color:var(--primary);"></i>
        User Details
      </h1>
    </div>
    <div style="display:flex;gap:8px;">
      <a href="/admin/settings" style="background:white;padding:8px 12px;border-radius:12px;border:1px solid var(--border);text-decoration:none;">
        <i class="fa-solid fa-gear" style="color:var(--primary);"></i>
      </a>
      <a href="/auth/logout" style="background:white;padding:8px 12px;border-radius:12px;border:1px solid var(--border);text-decoration:none;">
        <i class="fa-solid fa-right-from-bracket" style="color:var(--danger);"></i>
      </a>
    </div>
  </header>

  <!-- HERO BANNER -->
  <div class="balance-card">
    <div>
      <div class="balance-label">Account Balance</div>
      <div class="balance-title">$<%= parseFloat(user.balance || 0).toFixed(2) %></div>
    </div>
    <div class="hero-icon"><i class="fa-solid fa-wallet"></i></div>
  </div>

  <!-- ACTION BAR -->
  <div class="action-bar">
    <a href="/admin/fund?userId=<%= user.id %>" class="btn btn-primary">
      <i class="fa-solid fa-money-bill-transfer"></i> Fund / Deduct
    </a>
    <form method="POST" action="/admin/users/<%= user.id %>/suspend" style="display:inline;" onsubmit="return confirm('Toggle suspend status?')">
      <input type="hidden" name="action" value="<%= user.is_suspended ? 'unsuspend' : 'suspend' %>">
      <button type="submit" class="btn <%= user.is_suspended ? 'btn-warning' : 'btn-warning' %>">
        <i class="fa-solid <%= user.is_suspended ? 'fa-play' : 'fa-pause' %>"></i>
        <%= user.is_suspended ? 'Unsuspend' : 'Suspend' %>
      </button>
    </form>
    <form method="POST" action="/admin/users/<%= user.id %>/delete" style="display:inline;" onsubmit="return confirm('Are you sure? This will permanently delete the user and all data.')">
      <button type="submit" class="btn btn-danger">
        <i class="fa-solid fa-trash"></i> Delete
      </button>
    </form>
  </div>

  <!-- MAIN GRID -->
  <div id="main-grid">

    <!-- ── LEFT: DETAILS ── -->
    <div>

      <!-- Profile Card -->
      <div class="f-card">
        <div class="profile-header">
          <div class="profile-avatar">
            <%= user.first_name.charAt(0).toUpperCase() %><%= user.last_name.charAt(0).toUpperCase() %>
          </div>
          <div class="profile-info">
            <h2><%= user.first_name %> <%= user.last_name %></h2>
            <p><i class="fa-solid fa-envelope" style="margin-right:4px;"></i> <%= user.email %></p>
            <div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap;">
              <% if (user.kyc_status === 'approved') { %>
                <span class="status-badge badge-success"><i class="fa-solid fa-circle" style="font-size:8px;"></i> KYC Approved</span>
              <% } else if (user.kyc_status === 'pending') { %>
                <span class="status-badge badge-warning"><i class="fa-solid fa-circle" style="font-size:8px;"></i> KYC Pending</span>
              <% } else { %>
                <span class="status-badge badge-danger"><i class="fa-solid fa-circle" style="font-size:8px;"></i> KYC <%= user.kyc_status %></span>
              <% } %>
              
              <% if (user.is_suspended) { %>
                <span class="status-badge badge-danger"><i class="fa-solid fa-circle" style="font-size:8px;"></i> Suspended</span>
              <% } else { %>
                <span class="status-badge badge-success"><i class="fa-solid fa-circle" style="font-size:8px;"></i> Active</span>
              <% } %>
              
              <% if (user.email_verified) { %>
                <span class="status-badge badge-info"><i class="fa-solid fa-circle" style="font-size:8px;"></i> Verified</span>
              <% } %>
            </div>
          </div>
        </div>

        <h6>
          <span class="section-icon"><i class="fa-solid fa-id-card"></i></span>
          Account Information
        </h6>
        <div class="info-grid">
          <div class="info-item">
            <div class="info-label">Account Number</div>
            <div class="info-value"><%= user.account_number || 'N/A' %></div>
          </div>
          <div class="info-item">
            <div class="info-label">Phone</div>
            <div class="info-value"><%= user.phone || 'Not provided' %></div>
          </div>
          <div class="info-item">
            <div class="info-label">User ID</div>
            <div class="info-value">#<%= user.id %></div>
          </div>
          <div class="info-item">
            <div class="info-label">Joined</div>
            <div class="info-value"><%= new Date(user.created_at).toLocaleDateString() %></div>
          </div>
          <div class="info-item">
            <div class="info-label">Account Created</div>
            <div class="info-value"><%= user.account_created ? new Date(user.account_created).toLocaleDateString() : 'N/A' %></div>
          </div>
          <div class="info-item">
            <div class="info-label">Last Updated</div>
            <div class="info-value"><%= user.updated_at ? new Date(user.updated_at).toLocaleDateString() : 'N/A' %></div>
          </div>
        </div>
      </div>

      <!-- Transactions -->
      <div class="f-card">
        <h6>
          <span class="section-icon"><i class="fa-solid fa-money-bill-transfer"></i></span>
          Recent Transactions
        </h6>
        <% if (transactions && transactions.length > 0) { %>
          <table class="f-table">
            <thead>
              <tr>
                <th>Type</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Date</th>
                <th>Description</th>
              </tr>
            </thead>
            <tbody>
              <% transactions.forEach(tx => { %>
                <tr>
                  <td>
                    <span class="tx-type tx-<%= tx.type.includes('credit') || tx.type === 'deposit' ? 'credit' : 'debit' %>">
                      <i class="fa-solid <%= tx.type.includes('credit') || tx.type === 'deposit' ? 'fa-arrow-up' : 'fa-arrow-down' %>"></i>
                      <%= tx.type.replace('_', ' ').toUpperCase() %>
                    </span>
                  </td>
                  <td class="tx-amount">$<%= parseFloat(tx.amount).toFixed(2) %></td>
                  <td>
                    <% if (tx.status === 'completed') { %>
                      <span class="status-badge badge-success"><%= tx.status %></span>
                    <% } else if (tx.status === 'pending') { %>
                      <span class="status-badge badge-warning"><%= tx.status %></span>
                    <% } else { %>
                      <span class="status-badge badge-danger"><%= tx.status %></span>
                    <% } %>
                  </td>
                  <td style="color:var(--text-muted);font-size:12px;"><%= new Date(tx.created_at).toLocaleDateString() %></td>
                  <td style="color:var(--text-muted);font-size:12px;"><%= tx.description || '-' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <div class="empty-state">
            <i class="fa-solid fa-receipt"></i>
            <p>No transactions yet</p>
          </div>
        <% } %>
      </div>

    </div>

    <!-- ── RIGHT: SIDEBAR ── -->
    <div>

      <!-- KYC Documents -->
      <div class="f-card">
        <h6>
          <span class="section-icon"><i class="fa-solid fa-id-card-clip"></i></span>
          KYC Documents
        </h6>
        <% if (kycDocs && kycDocs.length > 0) { %>
          <div style="display:flex;flex-direction:column;gap:10px;">
            <% kycDocs.forEach(doc => { %>
              <div style="padding:12px 16px;background:var(--bg-body);border-radius:14px;border:1px solid var(--border);">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                  <span style="font-size:13px;font-weight:600;"><%= doc.document_type.toUpperCase() %></span>
                  <% if (doc.status === 'approved') { %>
                    <span class="status-badge badge-success"><%= doc.status %></span>
                  <% } else if (doc.status === 'pending') { %>
                    <span class="status-badge badge-warning"><%= doc.status %></span>
                  <% } else { %>
                    <span class="status-badge badge-danger"><%= doc.status %></span>
                  <% } %>
                </div>
                <div style="font-size:11px;color:var(--text-muted);">
                  Submitted <%= new Date(doc.submitted_at).toLocaleDateString() %>
                </div>
                <% if (doc.admin_notes) { %>
                  <div style="font-size:11px;color:var(--text-muted);margin-top:4px;font-style:italic;">
                    Note: <%= doc.admin_notes %>
                  </div>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-state" style="padding:20px;">
            <i class="fa-solid fa-folder-open"></i>
            <p style="font-size:13px;">No KYC documents submitted</p>
          </div>
        <% } %>
      </div>

      <!-- Quick Nav -->
      <div class="f-card">
        <h6>
          <span class="section-icon"><i class="fa-solid fa-bolt"></i></span>
          Quick Navigation
        </h6>
        <a href="/admin/users" class="quick-link">
          <div class="ql-icon" style="background:linear-gradient(135deg,var(--primary),var(--accent));"><i class="fa-solid fa-users"></i></div>
          <div><div class="ql-label">All Users</div><div class="ql-sub">Back to user list</div></div>
          <i class="fa-solid fa-chevron-right ql-arrow"></i>
        </a>
        <a href="/admin/users/create" class="quick-link">
          <div class="ql-icon" style="background:linear-gradient(135deg,#3b82f6,#2563eb);"><i class="fa-solid fa-user-plus"></i></div>
          <div><div class="ql-label">Create User</div><div class="ql-sub">Add another account</div></div>
          <i class="fa-solid fa-chevron-right ql-arrow"></i>
        </a>
        <a href="/admin/kyc" class="quick-link">
          <div class="ql-icon" style="background:linear-gradient(135deg,#f59e0b,#fbbf24);"><i class="fa-solid fa-id-card-clip"></i></div>
          <div><div class="ql-label">Review KYC</div><div class="ql-sub">Check pending approvals</div></div>
          <i class="fa-solid fa-chevron-right ql-arrow"></i>
        </a>
        <a href="/admin/dashboard" class="quick-link">
          <div class="ql-icon" style="background:linear-gradient(135deg,#64748b,#475569);"><i class="fa-solid fa-house-chimney"></i></div>
          <div><div class="ql-label">Dashboard</div><div class="ql-sub">Back to overview</div></div>
          <i class="fa-solid fa-chevron-right ql-arrow"></i>
        </a>
      </div>

    </div>
  </div><!-- /main-grid -->
</div>

<!-- Mobile Nav -->
<nav class="mobile-nav">
  <a href="/admin/dashboard" class="nav-item"><i class="fa-solid fa-house-chimney"></i>Home</a>
  <a href="/admin/users"     class="nav-item active"><i class="fa-solid fa-users"></i>Users</a>
  <a href="/admin/kyc"       class="nav-item"><i class="fa-solid fa-id-card"></i>KYC</a>
  <a href="/admin/settings"  class="nav-item"><i class="fa-solid fa-gear"></i>Settings</a>
</nav>

</body>
</html>