<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Finora Bank</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --primary: #0F6E56;
            --accent: #1D9E75;
            --bg-body: #F4F8F7;
            --white: #FFFFFF;
            --text-main: #0D1B16;
            --text-muted: #64748B;
            --border: #E8EFED;
            --danger: #ef4444;
            --success: #22c55e;
            --warning: #f59e0b;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            padding-bottom: 90px;
        }

        .main-content { padding: 20px; max-width: 1200px; margin: 0 auto; }

        .flash-message {
            padding: 14px 18px; border-radius: 12px; margin-bottom: 20px;
            font-size: 14px; display: flex; align-items: center; gap: 10px;
        }
        .flash-danger  { background: #fef2f2; color: var(--danger);  border: 1px solid #fecaca; }
        .flash-success { background: #f0fdf4; color: var(--success); border: 1px solid #bbf7d0; }

        .balance-card {
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            border-radius: 24px; padding: 32px; color: white;
            margin-bottom: 20px; box-shadow: 0 15px 35px rgba(15, 110, 86, 0.3);
        }
        .balance-label { font-size: 14px; opacity: 0.9; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
        .balance-amount { font-size: 2.5rem; font-weight: 800; margin-bottom: 24px; letter-spacing: -1px; }

        .action-buttons { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
        .action-btn {
            background: rgba(255,255,255,0.15); backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.2); border-radius: 16px;
            padding: 16px 8px; color: white; text-decoration: none;
            text-align: center; transition: all 0.3s;
            display: flex; flex-direction: column; align-items: center; gap: 8px;
        }
        .action-btn:hover { background: rgba(255,255,255,0.25); transform: translateY(-3px); color: white; }
        .action-btn i {
            font-size: 24px; width: 48px; height: 48px;
            background: rgba(255,255,255,0.2); border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
        }
        .action-btn span { font-size: 12px; font-weight: 600; }

        .f-card {
            background: var(--white); border-radius: 24px; padding: 24px;
            border: 1px solid var(--border);
            box-shadow: 0 10px 30px -5px rgba(15, 110, 86, 0.05); height: 100%;
        }

        .stat-number { font-size: 2rem; font-weight: 800; color: var(--text-main); letter-spacing: -1px; }

        .status-badge {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 600;
        }
        .badge-success { background: #f0fdf4; color: var(--success); }
        .badge-warning { background: #fffbeb; color: var(--warning); }
        .badge-danger  { background: #fef2f2; color: var(--danger);  }
        .badge-primary { background: #f0fdf4; color: var(--primary); }

        .user-row {
            display: flex; align-items: center; justify-content: space-between;
            padding: 14px 16px; background: var(--bg-body);
            border-radius: 16px; margin-bottom: 10px; border: 1px solid var(--border);
        }
        .user-avatar { width: 42px; height: 42px; border-radius: 12px; object-fit: cover; }

        /* QUICK ACTION LINK */
        .quick-link {
            display: flex; align-items: center; gap: 3px; padding: 3px 6px;
            background: var(--bg-body); border: 1px solid var(--border);
            border-radius: 16px; margin-bottom: 10px; text-decoration: none;
            transition: all 0.2s;
        }
        .quick-link:hover { border-color: var(--accent); background: #f0fdf8; }
        .quick-link-icon {
            width: 44px; height: 44px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center; color: white; flex-shrink: 0;
        }

        /* MOBILE NAV */
        .mobile-nav {
            position: fixed; bottom: 0; left: 0; width: 100%;
            background: rgba(255,255,255,0.95); backdrop-filter: blur(10px);
            border-top: 1px solid var(--border);
            display: flex; justify-content: space-around;
            padding: 10px 0 25px 0; z-index: 1000;
        }
        .nav-item { text-align: center; color: var(--text-muted); text-decoration: none; font-size: 10px; font-weight: 700; }
        .nav-item.active { color: var(--primary); }
        .nav-item i { font-size: 20px; margin-bottom: 4px; display: block; }

        @media (max-width: 768px) {
            .balance-amount { font-size: 2rem; }
            .action-buttons { gap: 8px; }
            .action-btn { padding: 12px 4px; }
            .action-btn i { width: 40px; height: 40px; font-size: 20px; }
            .action-btn span { font-size: 11px; }
        }
        @media (min-width: 992px) {
            .main-content { padding: 40px; }
            .mobile-nav { display: none; }
            body { padding-bottom: 0; }
        }
    </style>
</head>
<body>

<div class="main-content">

    <!-- Flash Messages -->
    <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
        <div class="flash-message flash-success">
            <i class="fas fa-circle-check"></i> <%= success_msg %>
        </div>
    <% } %>
    <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
        <div class="flash-message flash-danger">
            <i class="fas fa-circle-exclamation"></i> <%= error_msg %>
        </div>
    <% } %>

    <!-- Header -->
    <header class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="small text-muted mb-0">Logged in as</p>
            <h1 class="h4 fw-bold mb-0">
                <i class="fa-solid fa-shield-halved me-2" style="color: var(--primary);"></i>
                Admin Panel
            </h1>
        </div>
        <div class="d-flex gap-2">
            <!-- 🔔 NOTIFICATIONS BELL -->
            <a href="/admin/notifications" class="bg-white p-2 rounded-3 border text-decoration-none position-relative">
                <i class="fa-solid fa-bell text-muted"></i>
            </a>
            <a href="/admin/settings" class="bg-white p-2 rounded-3 border text-decoration-none">
                <i class="fa-solid fa-gear text-muted"></i>
            </a>
            <a href="/auth/logout" class="bg-white p-2 rounded-3 border text-decoration-none">
                <i class="fa-solid fa-right-from-bracket text-danger"></i>
            </a>
        </div>
    </header>

    <!-- HERO STATS CARD -->
    <div class="balance-card">
        <div class="balance-label">Total Platform Balance</div>
        <div class="balance-amount">
            $<%= typeof stats !== 'undefined' ? parseFloat(stats.totalBalance).toLocaleString(undefined, {minimumFractionDigits: 2}) : '0.00' %>
        </div>

        <div class="action-buttons">
            <a href="/admin/users" class="action-btn">
                <i class="fa-solid fa-users"></i>
                <span>Users</span>
            </a>
            <a href="/admin/kyc" class="action-btn">
                <i class="fa-solid fa-id-card"></i>
                <span>KYC</span>
            </a>
            <a href="/admin/transactions" class="action-btn">
                <i class="fa-solid fa-money-bill-transfer"></i>
                <span>Transactions</span>
            </a>
            <!-- 🔔 NOTIFICATIONS QUICK ACTION -->
            <a href="/admin/notifications" class="action-btn">
                <i class="fa-solid fa-bell"></i>
                <span>Notify</span>
            </a>
        </div>
    </div>

    <!-- STATS ROW -->
    <div class="row g-4 mb-4">
        <div class="col-6 col-lg-3">
            <div class="f-card text-center">
                <div class="mb-2">
                    <span class="status-badge badge-primary"><i class="fa-solid fa-users"></i> Users</span>
                </div>
                <div class="stat-number"><%= typeof stats !== 'undefined' ? stats.users : 0 %></div>
                <div class="small text-muted mt-1">Total Registered</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="f-card text-center">
                <div class="mb-2">
                    <span class="status-badge badge-warning"><i class="fa-solid fa-clock"></i> KYC</span>
                </div>
                <div class="stat-number"><%= typeof stats !== 'undefined' ? stats.pendingKYC : 0 %></div>
                <div class="small text-muted mt-1">Pending Review</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="f-card text-center">
                <div class="mb-2">
                    <span class="status-badge badge-success"><i class="fa-solid fa-repeat"></i> Today</span>
                </div>
                <div class="stat-number"><%= typeof stats !== 'undefined' ? stats.todayTransactions : 0 %></div>
                <div class="small text-muted mt-1">Transactions</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="f-card text-center">
                <div class="mb-2">
                    <span class="status-badge badge-success"><i class="fa-solid fa-circle"></i> System</span>
                </div>
                <div class="stat-number" style="font-size:1.4rem; color: var(--success);">Online</div>
                <div class="small text-muted mt-1">All systems go</div>
            </div>
        </div>
    </div>

    <!-- QUICK ACTIONS + RECENT USERS -->
    <div class="row g-4">

        <!-- Quick Actions -->
        <div class="col-12 col-lg-4">
            <div class="f-card">
                <h6 class="fw-bold mb-4">Quick Actions</h6>

                <!-- Admin Profile -->
                <a href="/admin/profile" class="quick-link">
                    <div class="quick-link-icon" style="background:linear-gradient(135deg,#8b5cf6,#7c3aed);">
                        <i class="fa-solid fa-user-shield"></i>
                    </div>
                    <div class="px-2 py-2">
                        <div class="fw-bold small" style="color:var(--text-main);">My Profile</div>
                        <div class="small text-muted">Change password, email, name</div>
                    </div>
                    <i class="fa-solid fa-chevron-right text-muted ms-auto me-2"></i>
                </a>

                <a href="/admin/users/create" class="quick-link">
                    <div class="quick-link-icon" style="background:linear-gradient(135deg,var(--primary),var(--accent));">
                        <i class="fa-solid fa-user-plus"></i>
                    </div>
                    <div class="px-2 py-2">
                        <div class="fw-bold small" style="color:var(--text-main);">Create User</div>
                        <div class="small text-muted">Add new account</div>
                    </div>
                    <i class="fa-solid fa-chevron-right text-muted ms-auto me-2"></i>
                </a>

                <a href="/admin/kyc" class="quick-link">
                    <div class="quick-link-icon" style="background:linear-gradient(135deg,#f59e0b,#fbbf24);">
                        <i class="fa-solid fa-id-card-clip"></i>
                    </div>
                    <div class="px-2 py-2">
                        <div class="fw-bold small" style="color:var(--text-main);">Review KYC</div>
                        <div class="small text-muted"><%= typeof stats !== 'undefined' ? stats.pendingKYC : 0 %> pending</div>
                    </div>
                    <i class="fa-solid fa-chevron-right text-muted ms-auto me-2"></i>
                </a>

                <a href="/admin/fund" class="quick-link">
                    <div class="quick-link-icon" style="background:linear-gradient(135deg,#22c55e,#16a34a);">
                        <i class="fa-solid fa-wallet"></i>
                    </div>
                    <div class="px-2 py-2">
                        <div class="fw-bold small" style="color:var(--text-main);">Fund Account</div>
                        <div class="small text-muted">Credit / Debit user</div>
                    </div>
                    <i class="fa-solid fa-chevron-right text-muted ms-auto me-2"></i>
                </a>

                <!-- 🔔 NOTIFICATIONS QUICK LINK -->
                <a href="/admin/notifications" class="quick-link">
                    <div class="quick-link-icon" style="background:linear-gradient(135deg,#8b5cf6,#7c3aed);">
                        <i class="fa-solid fa-bell"></i>
                    </div>
                    <div class="px-2 py-2">
                        <div class="fw-bold small" style="color:var(--text-main);">Notifications</div>
                        <div class="small text-muted">Send messages to users</div>
                    </div>
                    <i class="fa-solid fa-chevron-right text-muted ms-auto me-2"></i>
                </a>

                <a href="/admin/settings" class="quick-link">
                    <div class="quick-link-icon" style="background:linear-gradient(135deg,#64748b,#475569);">
                        <i class="fa-solid fa-gear"></i>
                    </div>
                    <div class="px-2 py-2">
                        <div class="fw-bold small" style="color:var(--text-main);">Site Settings</div>
                        <div class="small text-muted">Configure platform</div>
                    </div>
                    <i class="fa-solid fa-chevron-right text-muted ms-auto me-2"></i>
                </a>

                <!-- Withdrawal Steps Configuration -->
                <a href="/admin/withdrawal-steps" class="quick-link">
                    <div class="quick-link-icon" style="background:linear-gradient(135deg,#ef4444,#f97316);">
                        <i class="fa-solid fa-file-invoice-dollar"></i>
                    </div>
                    <div class="px-2 py-2">
                        <div class="fw-bold small" style="color:var(--text-main);">Withdrawal Steps</div>
                        <div class="small text-muted">Configure KYC, OTP, Admin approval</div>
                    </div>
                    <i class="fa-solid fa-chevron-right text-muted ms-auto me-2"></i>
                </a>
                <a href="/admin/pending-withdrawals" class="quick-link">
                    <div class="quick-link-icon" style="background:linear-gradient(135deg,#ef4444,#f97316);">
                        <i class="fa-solid fa-file-invoice-dollar"></i>
                    </div>
                    <div class="px-2 py-2">
                        <div class="fw-bold small" style="color:var(--text-main);">Pending Withdrawals</div>
                        <div class="small text-muted">Configure KYC, OTP, Admin approval</div>
                    </div>
                    <i class="fa-solid fa-chevron-right text-muted ms-auto me-2"></i>
                </a>

                <!-- User Detail (Primary) -->
                <a href="/admin/users/1" class="quick-link">  <!-- Replace 1 with actual userId -->
                    <div class="quick-link-icon" style="background:linear-gradient(135deg,#3b82f6,#2563eb);">
                        <i class="fa-solid fa-user"></i>
                    </div>
                    <div class="px-2 py-2">
                        <div class="fw-bold small" style="color:var(--text-main);">User Detail</div>
                        <div class="small text-muted">View primary user profile</div>
                    </div>
                    <i class="fa-solid fa-chevron-right text-muted ms-auto me-2"></i>
                </a>


        <!-- Select User to View/Edit -->
            <a href="/admin/users/select" class="quick-link">
                <div class="quick-link-icon" style="background:linear-gradient(135deg,#3b82f6,#2563eb);">
                    <i class="fa-solid fa-users-viewfinder"></i>
                </div>
                <div class="px-2 py-2">
                    <div class="fw-bold small" style="color:var(--text-main);">Manage Users</div>
                    <div class="small text-muted">Search, view & edit users</div>
                </div>
                <i class="fa-solid fa-chevron-right text-muted ms-auto me-2"></i>
            </a>
            </div>
        </div>

        <!-- Recent Users -->
        <div class="col-12 col-lg-8">
            <div class="f-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h6 class="fw-bold mb-0">Recent Users</h6>
                    <a href="/admin/users" class="small text-decoration-none" style="color: var(--primary);">View All</a>
                </div>

                <% if (typeof recentUsers !== 'undefined' && recentUsers && recentUsers.length > 0) { %>
                    <% recentUsers.forEach(u => { %>
                        <div class="user-row">
                            <div class="d-flex align-items-center gap-3">
                                <img src="https://ui-avatars.com/api/?name=<%= u.first_name %>+<%= u.last_name %>&background=0F6E56&color=fff"
                                     class="user-avatar" alt="<%= u.first_name %>">
                                <div>
                                    <div class="fw-bold small"><%= u.first_name %> <%= u.last_name %></div>
                                    <div class="small text-muted"><%= u.email %></div>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <% if (u.kyc_status === 'approved') { %>
                                    <span class="status-badge badge-success" style="font-size:11px; padding: 4px 10px;">
                                        <i class="fa-solid fa-circle-check"></i> KYC
                                    </span>
                                <% } else if (u.kyc_status === 'pending') { %>
                                    <span class="status-badge badge-warning" style="font-size:11px; padding: 4px 10px;">
                                        <i class="fa-solid fa-clock"></i> Pending
                                    </span>
                                <% } else { %>
                                    <span class="status-badge badge-danger" style="font-size:11px; padding: 4px 10px;">
                                        <i class="fa-solid fa-xmark"></i> Unverified
                                    </span>
                                <% } %>
                                <a href="/admin/users/<%= u.id %>" class="btn btn-sm rounded-3 fw-bold"
                                   style="background: var(--bg-body); border: 1px solid var(--border); font-size:11px;">
                                    View
                                </a>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="text-center py-5 text-muted">
                        <i class="fa-solid fa-users fs-1 mb-3"></i>
                        <p>No users yet</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Mobile Nav — 5 items including Notifications -->
<nav class="mobile-nav">
    <a href="/admin/dashboard" class="nav-item active">
        <i class="fa-solid fa-house-chimney"></i>
        Home
    </a>
    <a href="/admin/users" class="nav-item">
        <i class="fa-solid fa-users"></i>
        Users
    </a>
    <a href="/admin/kyc" class="nav-item">
        <i class="fa-solid fa-id-card"></i>
        KYC
    </a>
    <!-- 🔔 NOTIFICATIONS IN MOBILE NAV -->
    <a href="/admin/notifications" class="nav-item">
        <i class="fa-solid fa-bell"></i>
        Notify
    </a>
    <a href="/admin/settings" class="nav-item">
        <i class="fa-solid fa-gear"></i>
        Settings
    </a>
</nav>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
