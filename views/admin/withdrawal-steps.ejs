<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Finora Bank Admin</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --primary: #0F6E56;
            --accent: #1D9E75;
            --bg-body: #F4F8F7;
            --white: #FFFFFF;
            --text-main: #0D1B16;
            --text-muted: #64748B;
            --border: #E8EFED;
            --danger: #ef4444;
            --success: #22c55e;
            --warning: #f59e0b;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            padding-bottom: 90px;
        }

        .main-content { padding: 20px; max-width: 1200px; margin: 0 auto; }

        .flash-message {
            padding: 14px 18px; border-radius: 12px; margin-bottom: 20px;
            font-size: 14px; display: flex; align-items: center; gap: 10px;
        }
        .flash-danger  { background: #fef2f2; color: var(--danger);  border: 1px solid #fecaca; }
        .flash-success { background: #f0fdf4; color: var(--success); border: 1px solid #bbf7d0; }

        .f-card {
            background: var(--white); border-radius: 24px; padding: 24px;
            border: 1px solid var(--border);
            box-shadow: 0 10px 30px -5px rgba(15, 110, 86, 0.05); height: 100%;
        }

        .step-card {
            background: var(--white); border-radius: 24px; padding: 24px;
            border: 1px solid var(--border); margin-bottom: 16px;
            box-shadow: 0 10px 30px -5px rgba(15, 110, 86, 0.05);
        }

        .step-number {
            width: 48px; height: 48px; border-radius: 14px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            color: white; display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem; font-weight: 800; flex-shrink: 0;
        }

        .status-badge {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 600;
        }
        .badge-success { background: #f0fdf4; color: var(--success); }
        .badge-warning { background: #fffbeb; color: var(--warning); }
        .badge-danger  { background: #fef2f2; color: var(--danger);  }
        .badge-primary { background: #f0fdf4; color: var(--primary); }

        .quick-link {
            display: flex; align-items: center; gap: 3px; padding: 3px 6px;
            background: var(--bg-body); border: 1px solid var(--border);
            border-radius: 16px; margin-bottom: 10px; text-decoration: none;
            transition: all 0.2s;
        }
        .quick-link:hover { border-color: var(--accent); background: #f0fdf8; }
        .quick-link-icon {
            width: 44px; height: 44px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center; color: white; flex-shrink: 0;
        }

        .mobile-nav {
            position: fixed; bottom: 0; left: 0; width: 100%;
            background: rgba(255,255,255,0.95); backdrop-filter: blur(10px);
            border-top: 1px solid var(--border);
            display: flex; justify-content: space-around;
            padding: 10px 0 25px 0; z-index: 1000;
        }
        .nav-item { text-align: center; color: var(--text-muted); text-decoration: none; font-size: 10px; font-weight: 700; }
        .nav-item.active { color: var(--primary); }
        .nav-item i { font-size: 20px; margin-bottom: 4px; display: block; }

        .step-form { display: none; margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border); }
        .step-form.active { display: block; }

        @media (max-width: 768px) {
            .main-content { padding: 15px; }
        }
        @media (min-width: 992px) {
            .main-content { padding: 40px; }
            .mobile-nav { display: none; }
            body { padding-bottom: 0; }
        }
    </style>
<base target="_blank">
</head>
<body>

<div class="main-content">

    <!-- Flash Messages -->
    <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
        <div class="flash-message flash-success">
            <i class="fas fa-circle-check"></i> <%= success_msg %>
        </div>
    <% } %>
    <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
        <div class="flash-message flash-danger">
            <i class="fas fa-circle-exclamation"></i> <%= error_msg %>
        </div>
    <% } %>

    <!-- Header -->
    <header class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="small text-muted mb-0">Admin Configuration</p>
            <h1 class="h4 fw-bold mb-0">
                <i class="fa-solid fa-file-invoice-dollar me-2" style="color: var(--primary);"></i>
                <%= title %>
            </h1>
        </div>
        <div class="d-flex gap-2">
            <a href="/admin/dashboard" class="bg-white p-2 rounded-3 border text-decoration-none">
                <i class="fa-solid fa-arrow-left text-muted"></i>
            </a>
            <a href="/admin/settings" class="bg-white p-2 rounded-3 border text-decoration-none">
                <i class="fa-solid fa-gear text-muted"></i>
            </a>
            <a href="/auth/logout" class="bg-white p-2 rounded-3 border text-decoration-none">
                <i class="fa-solid fa-right-from-bracket text-danger"></i>
            </a>
        </div>
    </header>

    <!-- Steps List -->
    <div class="row g-4">
        <% if (typeof steps !== 'undefined' && steps && steps.length > 0) { %>
            <% steps.forEach((step, index) => { %>
                <div class="col-12">
                    <div class="step-card">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex align-items-center gap-3">
                                <div class="step-number"><%= step.step_number %></div>
                                <div>
                                    <h5 class="fw-bold mb-1"><%= step.step_name %></h5>
                                    <code class="small text-muted"><%= step.step_code %></code>
                                    <p class="small text-muted mt-1 mb-0"><%= step.description %></p>
                                </div>
                            </div>
                            <span class="status-badge <%= step.is_active ? 'badge-success' : 'badge-danger' %>">
                                <i class="fa-solid fa-circle" style="font-size: 8px;"></i>
                                <%= step.is_active ? 'Active' : 'Inactive' %>
                            </span>
                        </div>

                        <!-- Toggle & Edit Buttons -->
                        <div class="d-flex gap-2 mb-3">
                            <button class="btn btn-sm btn-outline-primary" onclick="toggleEditForm('<%= step.id %>')">
                                <i class="fa-solid fa-pen me-1"></i> Edit
                            </button>
                            <button class="btn btn-sm <%= step.is_active ? 'btn-outline-danger' : 'btn-outline-success' %>" 
                                    onclick="toggleStepStatus('<%= step.id %>', <%= !step.is_active %>)">
                                <i class="fa-solid <%= step.is_active ? 'fa-ban' : 'fa-check' %> me-1"></i>
                                <%= step.is_active ? 'Disable' : 'Enable' %>
                            </button>
                        </div>

                        <!-- Edit Form (Hidden by default) -->
                        <div id="edit-form-<%= step.id %>" class="step-form">
                            <form action="/admin/withdrawal-steps/<%= step.id %>" method="POST">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold">Step Code</label>
                                        <input type="text" name="step_code" class="form-control" value="<%= step.step_code %>" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold">Step Name</label>
                                        <input type="text" name="step_name" class="form-control" value="<%= step.step_name %>" required>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label small fw-bold">Description</label>
                                        <textarea name="description" class="form-control" rows="2"><%= step.description %></textarea>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold">Validation Rules (JSON)</label>
                                        <textarea name="validation_rules" class="form-control" rows="3" placeholder='{"requires_document": true, "document_types": ["pdf", "jpg"]}'><%= typeof step.validation_rules === 'string' ? step.validation_rules : JSON.stringify(step.validation_rules || {}) %></textarea>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold">Rejection Reasons (JSON array)</label>
                                        <textarea name="rejection_reasons" class="form-control" rows="3" placeholder='["Document unclear", "Invalid format"]'><%= typeof step.rejection_reasons === 'string' ? step.rejection_reasons : JSON.stringify(step.rejection_reasons || []) %></textarea>
                                    </div>
                                    <div class="col-12">
                                        <div class="form-check">
                                            <input type="checkbox" name="is_required" class="form-check-input" <%= step.is_required ? 'checked' : '' %>>
                                            <label class="form-check-label small">Required Step</label>
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <button type="submit" class="btn btn-primary">
                                            <i class="fa-solid fa-save me-1"></i> Save Changes
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary" onclick="toggleEditForm('<%= step.id %>')">
                                            Cancel
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12 text-center py-5 text-muted">
                <i class="fa-solid fa-gear fs-1 mb-3"></i>
                <p>No withdrawal steps configured</p>
                <a href="/admin/dashboard" class="btn btn-primary mt-3">Back to Dashboard</a>
            </div>
        <% } %>
    </div>
</div>

<!-- Mobile Nav -->
<nav class="mobile-nav">
    <a href="/admin/dashboard" class="nav-item">
        <i class="fa-solid fa-house-chimney"></i>
        Home
    </a>
    <a href="/admin/users" class="nav-item">
        <i class="fa-solid fa-users"></i>
        Users
    </a>
    <a href="/admin/kyc" class="nav-item">
        <i class="fa-solid fa-id-card"></i>
        KYC
    </a>
    <a href="/admin/notifications" class="nav-item">
        <i class="fa-solid fa-bell"></i>
        Notify
    </a>
    <a href="/admin/settings" class="nav-item">
        <i class="fa-solid fa-gear"></i>
        Settings
    </a>
</nav>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function toggleEditForm(id) {
        const form = document.getElementById('edit-form-' + id);
        form.classList.toggle('active');
    }

    async function toggleStepStatus(id, active) {
        if (!confirm(active ? 'Enable this step?' : 'Disable this step?')) return;
        
        try {
            const res = await fetch(`/admin/withdrawal-steps/${id}/toggle`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ active })
            });
            
            const data = await res.json();
            if (data.success) {
                location.reload();
            } else {
                alert('Failed to toggle step: ' + (data.message || 'Unknown error'));
            }
        } catch (err) {
            alert('Network error. Please try again.');
        }
    }
</script>
</body>
</html>