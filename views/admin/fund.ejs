<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Finora Bank</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --primary: #0F6E56;
            --accent: #1D9E75;
            --bg-body: #F4F8F7;
            --white: #FFFFFF;
            --text-main: #0D1B16;
            --text-muted: #64748B;
            --border: #E8EFED;
            --danger: #ef4444;
            --success: #22c55e;
            --warning: #f59e0b;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            padding-bottom: 90px;
        }

        .main-content { padding: 20px; max-width: 1200px; margin: 0 auto; }

        .flash-message {
            padding: 14px 18px; border-radius: 12px; margin-bottom: 20px;
            font-size: 14px; display: flex; align-items: center; gap: 10px;
        }
        .flash-danger  { background: #fef2f2; color: var(--danger);  border: 1px solid #fecaca; }
        .flash-success { background: #f0fdf4; color: var(--success); border: 1px solid #bbf7d0; }

        /* HERO */
        .balance-card {
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            border-radius: 24px; padding: 32px; color: white;
            margin-bottom: 24px;
            box-shadow: 0 15px 35px rgba(15, 110, 86, 0.3);
        }
        .balance-label { font-size: 14px; opacity: 0.9; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
        .balance-amount { font-size: 2.2rem; font-weight: 800; margin-bottom: 6px; letter-spacing: -1px; }

        .f-card {
            background: var(--white);
            border-radius: 24px; padding: 24px;
            border: 1px solid var(--border);
            box-shadow: 0 10px 30px -5px rgba(15, 110, 86, 0.05);
            margin-bottom: 16px;
        }

        /* USER SEARCH */
        .search-input {
            background: var(--bg-body); border: 1px solid var(--border);
            border-radius: 16px; padding: 14px 18px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 14px; width: 100%; outline: none;
            transition: border-color 0.2s;
        }
        .search-input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(15,110,86,0.1); }

        /* USER ROW */
        .user-row {
            display: flex; align-items: center; justify-content: space-between;
            padding: 16px; background: var(--bg-body);
            border-radius: 16px; margin-bottom: 10px;
            border: 1px solid var(--border); cursor: pointer;
            transition: all 0.2s;
        }
        .user-row:hover { border-color: var(--primary); background: #f0fdf4; transform: translateX(4px); }
        .user-row.selected { border-color: var(--primary); background: #f0fdf4; }

        .user-avatar {
            width: 46px; height: 46px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-weight: 800; font-size: 16px; color: white;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            flex-shrink: 0;
        }

        /* FORM */
        .form-label { font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px; }

        .form-control {
            background: var(--bg-body); border: 1px solid var(--border);
            border-radius: 14px; padding: 14px 16px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 15px; font-weight: 600;
            transition: border-color 0.2s;
        }
        .form-control:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(15,110,86,0.1); background: var(--white); }

        /* TAB BUTTONS */
        .tab-group { display: flex; gap: 10px; margin-bottom: 24px; }
        .tab-btn {
            flex: 1; padding: 14px; border-radius: 16px;
            border: 2px solid var(--border); background: var(--bg-body);
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 700; font-size: 14px; cursor: pointer;
            transition: all 0.2s; color: var(--text-muted);
            display: flex; align-items: center; justify-content: center; gap: 8px;
        }
        .tab-btn.active-credit { border-color: var(--success); background: #f0fdf4; color: var(--success); }
        .tab-btn.active-debit  { border-color: var(--danger);  background: #fef2f2; color: var(--danger);  }

        /* SUBMIT BUTTONS */
        .btn-credit {
            background: linear-gradient(135deg, var(--primary), var(--accent));
            color: white; border: none; padding: 16px 32px;
            border-radius: 16px; font-weight: 700; font-size: 15px;
            cursor: pointer; transition: all 0.2s; width: 100%;
            display: flex; align-items: center; justify-content: center; gap: 10px;
        }
        .btn-credit:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(15,110,86,0.3); }

        .btn-debit {
            background: linear-gradient(135deg, var(--danger), #f87171);
            color: white; border: none; padding: 16px 32px;
            border-radius: 16px; font-weight: 700; font-size: 15px;
            cursor: pointer; transition: all 0.2s; width: 100%;
            display: flex; align-items: center; justify-content: center; gap: 10px;
        }
        .btn-debit:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(239,68,68,0.3); }

        /* SELECTED USER PREVIEW */
        .selected-preview {
            background: var(--bg-body); border: 2px solid var(--primary);
            border-radius: 16px; padding: 16px;
            display: none; margin-bottom: 20px;
            align-items: center; gap: 14px;
        }
        .selected-preview.show { display: flex; }

        /* MOBILE NAV */
        .mobile-nav {
            position: fixed; bottom: 0; left: 0; width: 100%;
            background: rgba(255,255,255,0.95); backdrop-filter: blur(10px);
            border-top: 1px solid var(--border);
            display: flex; justify-content: space-around;
            padding: 10px 0 25px 0; z-index: 1000;
        }
        .nav-item { text-align: center; color: var(--text-muted); text-decoration: none; font-size: 10px; font-weight: 700; }
        .nav-item.active { color: var(--primary); }
        .nav-item i { font-size: 20px; margin-bottom: 4px; display: block; }

        @media (min-width: 992px) {
            .main-content { padding: 40px; }
            .mobile-nav { display: none; }
            body { padding-bottom: 0; }
        }
    </style>
</head>
<body>

<div class="main-content">

    <!-- Flash Messages -->
    <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
        <div class="flash-message flash-success">
            <i class="fas fa-circle-check"></i> <%= success_msg %>
        </div>
    <% } %>
    <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
        <div class="flash-message flash-danger">
            <i class="fas fa-circle-exclamation"></i> <%= error_msg %>
        </div>
    <% } %>

    <!-- Header -->
    <header class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="small text-muted mb-0">
                <a href="/admin/dashboard" class="text-decoration-none" style="color:var(--primary);">
                    <i class="fa-solid fa-arrow-left me-1"></i> Dashboard
                </a>
            </p>
            <h1 class="h4 fw-bold mb-0">Fund / Deduct Account</h1>
        </div>
        <a href="/auth/logout" class="bg-white p-2 rounded-3 border text-decoration-none">
            <i class="fa-solid fa-right-from-bracket text-danger"></i>
        </a>
    </header>

    <!-- HERO -->
    <div class="balance-card">
        <div class="balance-label">Account Management</div>
        <div class="balance-amount">
            <i class="fa-solid fa-wallet me-2" style="opacity:0.8;"></i>
            Fund / Deduct
        </div>
        <div style="opacity:0.85; font-size:14px;">
            Select a user below to credit or debit their account
        </div>
    </div>

    <div class="row g-4">

        <!-- LEFT: User List -->
        <div class="col-12 col-lg-5">
            <div class="f-card">
                <h6 class="fw-bold mb-3">Select User</h6>

                <input type="text" class="search-input mb-4"
                       id="userSearch" placeholder="🔍  Search by name or email..."
                       onkeyup="filterUsers()">

                <div id="userList" style="max-height: 450px; overflow-y: auto;">
                    <% if (typeof users !== 'undefined' && users && users.length > 0) { %>
                        <% users.forEach(u => { %>
                            <div class="user-row"
                                 data-name="<%= (u.first_name + ' ' + u.last_name).toLowerCase() %>"
                                 data-email="<%= u.email.toLowerCase() %>"
                                 onclick="selectUser(<%= u.id %>, '<%= u.first_name %> <%= u.last_name %>', '<%= u.email %>', '<%= u.account_number || 'N/A' %>', '<%= parseFloat(u.balance || 0).toFixed(2) %>')">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="user-avatar">
                                        <%= u.first_name ? u.first_name[0].toUpperCase() : 'U' %>
                                    </div>
                                    <div>
                                        <div class="fw-bold small"><%= u.first_name %> <%= u.last_name %></div>
                                        <div class="small text-muted"><%= u.email %></div>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold small" style="color:var(--primary);">
                                        $<%= parseFloat(u.balance || 0).toLocaleString(undefined, {minimumFractionDigits:2}) %>
                                    </div>
                                    <div class="small text-muted" style="font-size:10px;">Balance</div>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="text-center py-4 text-muted">
                            <i class="fa-solid fa-users fs-2 mb-2"></i>
                            <p class="small">No users found</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- RIGHT: Action Form -->
        <div class="col-12 col-lg-7">
            <div class="f-card">
                <h6 class="fw-bold mb-4">Transaction Details</h6>

                <!-- Selected User Preview -->
                <div class="selected-preview" id="selectedPreview">
                    <div class="user-avatar" id="previewAvatar">?</div>
                    <div>
                        <div class="fw-bold" id="previewName">No user selected</div>
                        <div class="small text-muted" id="previewEmail"></div>
                        <div class="small mt-1">
                            Balance: <strong style="color:var(--primary);" id="previewBalance">$0.00</strong>
                            &nbsp;·&nbsp; Acc: <strong id="previewAcc">N/A</strong>
                        </div>
                    </div>
                </div>

                <!-- Tab: Credit / Debit -->
                <div class="tab-group">
                    <button class="tab-btn active-credit" id="tabCredit" onclick="switchTab('credit')">
                        <i class="fa-solid fa-plus-circle"></i> Credit Account
                    </button>
                    <button class="tab-btn" id="tabDebit" onclick="switchTab('debit')">
                        <i class="fa-solid fa-minus-circle"></i> Debit Account
                    </button>
                </div>

                <!-- Credit Form -->
                <form id="creditForm" action="/admin/fund" method="POST">
                    <input type="hidden" name="userId" id="creditUserId">
                    <div class="mb-3">
                        <label class="form-label">Amount to Credit ($)</label>
                        <input type="number" name="amount" class="form-control"
                               placeholder="0.00" min="0.01" step="0.01" required
                               style="font-size:1.4rem; font-weight:800; color:var(--success); text-align:center;">
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Description / Note</label>
                        <input type="text" name="description" class="form-control"
                               placeholder="e.g. Account top-up, Bonus credit...">
                    </div>
                    <button type="submit" class="btn-credit">
                        <i class="fa-solid fa-plus-circle"></i> Credit Account
                    </button>
                </form>

                <!-- Debit Form -->
                <form id="debitForm" action="/admin/deduct" method="POST" style="display:none;">
                    <input type="hidden" name="userId" id="debitUserId">
                    <div class="mb-3">
                        <label class="form-label">Amount to Debit ($)</label>
                        <input type="number" name="amount" class="form-control"
                               placeholder="0.00" min="0.01" step="0.01" required
                               style="font-size:1.4rem; font-weight:800; color:var(--danger); text-align:center;">
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Description / Note</label>
                        <input type="text" name="description" class="form-control"
                               placeholder="e.g. Charge, Fee deduction...">
                    </div>
                    <button type="submit" class="btn-debit">
                        <i class="fa-solid fa-minus-circle"></i> Debit Account
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>

<!-- Mobile Nav -->
<nav class="mobile-nav">
    <a href="/admin/dashboard" class="nav-item">
        <i class="fa-solid fa-house-chimney"></i> Home
    </a>
    <a href="/admin/users" class="nav-item">
        <i class="fa-solid fa-users"></i> Users
    </a>
    <a href="/admin/kyc" class="nav-item">
        <i class="fa-solid fa-id-card"></i> KYC
    </a>
    <a href="/admin/settings" class="nav-item">
        <i class="fa-solid fa-gear"></i> Settings
    </a>
</nav>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    let activeTab = 'credit';

    function selectUser(id, name, email, acc, balance) {
        // Update hidden inputs
        document.getElementById('creditUserId').value = id;
        document.getElementById('debitUserId').value  = id;

        // Update preview
        document.getElementById('previewAvatar').textContent  = name[0].toUpperCase();
        document.getElementById('previewName').textContent    = name;
        document.getElementById('previewEmail').textContent   = email;
        document.getElementById('previewBalance').textContent = '$' + parseFloat(balance).toLocaleString(undefined, {minimumFractionDigits:2});
        document.getElementById('previewAcc').textContent     = acc;
        document.getElementById('selectedPreview').classList.add('show');

        // Highlight selected row
        document.querySelectorAll('.user-row').forEach(r => r.classList.remove('selected'));
        event.currentTarget.classList.add('selected');
    }

    function switchTab(tab) {
        activeTab = tab;
        const creditForm = document.getElementById('creditForm');
        const debitForm  = document.getElementById('debitForm');
        const tabCredit  = document.getElementById('tabCredit');
        const tabDebit   = document.getElementById('tabDebit');

        if (tab === 'credit') {
            creditForm.style.display = 'block';
            debitForm.style.display  = 'none';
            tabCredit.className = 'tab-btn active-credit';
            tabDebit.className  = 'tab-btn';
        } else {
            creditForm.style.display = 'none';
            debitForm.style.display  = 'block';
            tabCredit.className = 'tab-btn';
            tabDebit.className  = 'tab-btn active-debit';
        }
    }

    function filterUsers() {
        const q = document.getElementById('userSearch').value.toLowerCase();
        document.querySelectorAll('.user-row').forEach(row => {
            const name  = row.dataset.name  || '';
            const email = row.dataset.email || '';
            row.style.display = (name.includes(q) || email.includes(q)) ? 'flex' : 'none';
        });
    }
</script>
</body>
</html>
