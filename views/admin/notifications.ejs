<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notifications - Admin</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #F4F8F7;
            color: #0D1B16;
            padding-bottom: 40px;
        }

        .main-content { padding: 20px; max-width: 1100px; margin: 0 auto; }

        .flash-message {
            padding: 14px 18px; border-radius: 12px; margin-bottom: 20px;
            font-size: 14px; display: flex; align-items: center; gap: 10px;
        }
        .flash-danger  { background: #fef2f2; color: #ef4444; border: 1px solid #fecaca; }
        .flash-success { background: #f0fdf4; color: #22c55e; border: 1px solid #bbf7d0; }

        /* HERO */
        .hero-card {
            background: linear-gradient(135deg, #0F6E56 0%, #1D9E75 100%);
            border-radius: 24px; padding: 28px 32px; color: white;
            margin-bottom: 24px;
            box-shadow: 0 15px 35px rgba(15,110,86,0.3);
            display: flex; align-items: center; justify-content: space-between; gap: 20px;
        }
        .hero-card h1 { font-size: 1.6rem; font-weight: 800; margin: 0; }
        .hero-card p  { font-size: 14px; opacity: 0.85; margin: 4px 0 0; }
        .hero-icon {
            width: 56px; height: 56px; background: rgba(255,255,255,0.15);
            border-radius: 16px; display: flex; align-items: center;
            justify-content: center; font-size: 24px; flex-shrink: 0;
        }

        /* CARDS */
        .f-card {
            background: #fff; border-radius: 24px; padding: 28px;
            border: 1px solid #E8EFED;
            box-shadow: 0 10px 30px -5px rgba(15,110,86,0.05);
            height: 100%;
        }

        .card-title {
            font-size: 15px; font-weight: 800; margin-bottom: 6px;
            display: flex; align-items: center; gap: 10px;
        }
        .card-title-icon {
            width: 36px; height: 36px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; flex-shrink: 0;
        }
        .icon-broadcast { background: #E1F5EE; color: #0F6E56; }
        .icon-personal  { background: #eff6ff; color: #3b82f6; }

        .card-sub { font-size: 13px; color: #64748B; margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid #E8EFED; }

        /* FORM */
        .form-label { font-size: 13px; font-weight: 700; color: #0D1B16; margin-bottom: 8px; display: block; }

        .form-control, .form-select {
            background: #F4F8F7; border: 1.5px solid #E8EFED;
            border-radius: 14px; padding: 12px 16px; font-size: 14px;
            font-family: 'Plus Jakarta Sans', sans-serif; color: #0D1B16;
            width: 100%; outline: none; transition: border 0.2s, box-shadow 0.2s;
        }
        .form-control:focus, .form-select:focus {
            border-color: #0F6E56; box-shadow: 0 0 0 3px rgba(15,110,86,0.1);
            background: #fff;
        }
        textarea.form-control { resize: vertical; min-height: 110px; }

        .btn-send {
            border: none; border-radius: 14px; padding: 13px 24px;
            font-size: 14px; font-weight: 700;
            font-family: 'Plus Jakarta Sans', sans-serif;
            cursor: pointer; width: 100%; display: flex;
            align-items: center; justify-content: center; gap: 8px;
            transition: background 0.2s, transform 0.15s; margin-top: 4px;
        }
        .btn-send:hover { transform: translateY(-1px); }
        .btn-broadcast { background: #0F6E56; color: #fff; }
        .btn-broadcast:hover { background: #1D9E75; }
        .btn-personal  { background: #3b82f6; color: #fff; }
        .btn-personal:hover  { background: #2563eb; }

        /* USER SELECT */
        .user-select-wrap { position: relative; }
        .user-search {
            background: #F4F8F7; border: 1.5px solid #E8EFED;
            border-radius: 14px 14px 0 0; padding: 10px 16px;
            font-size: 13px; font-family: 'Plus Jakarta Sans', sans-serif;
            width: 100%; outline: none; border-bottom: none;
        }
        .user-search:focus { border-color: #0F6E56; box-shadow: 0 0 0 3px rgba(15,110,86,0.1); }
        .form-select.user-select { border-radius: 0 0 14px 14px; border-top: 1px solid #E8EFED; }

        /* HISTORY TABLE */
        .section-label {
            font-size: 12px; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.8px; color: #64748B; margin-bottom: 16px;
            padding-bottom: 10px; border-bottom: 1px solid #E8EFED;
        }

        .notif-row {
            display: flex; align-items: flex-start; gap: 14px;
            padding: 14px 16px; border-radius: 14px;
            background: #F4F8F7; border: 1px solid #E8EFED;
            margin-bottom: 8px; transition: transform 0.15s;
        }
        .notif-row:hover { transform: translateX(3px); }
        .notif-row:last-child { margin-bottom: 0; }

        .notif-row-icon {
            width: 40px; height: 40px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; flex-shrink: 0;
        }
        .row-icon-general  { background: #E1F5EE; color: #0F6E56; }
        .row-icon-personal { background: #eff6ff; color: #3b82f6; }

        .notif-row-body { flex: 1; min-width: 0; }
        .notif-row-title    { font-size: 13px; font-weight: 700; color: #0D1B16; margin-bottom: 2px; }
        .notif-row-message  { font-size: 12px; color: #64748B; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .notif-row-meta     { font-size: 11px; color: #94a3b8; display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }

        .notif-badge {
            display: inline-flex; align-items: center; gap: 3px;
            padding: 2px 8px; border-radius: 10px;
            font-size: 10px; font-weight: 700;
        }
        .nb-general  { background: #E1F5EE; color: #0F6E56; }
        .nb-personal { background: #eff6ff; color: #3b82f6; }

        .btn-delete {
            background: none; border: none; cursor: pointer;
            color: #ef4444; font-size: 14px; padding: 6px 8px;
            border-radius: 8px; transition: background 0.15s; flex-shrink: 0;
        }
        .btn-delete:hover { background: #fef2f2; }

        /* EMPTY */
        .empty-mini { text-align: center; padding: 40px 20px; color: #64748B; }
        .empty-mini i { font-size: 32px; opacity: 0.3; display: block; margin-bottom: 10px; }

        @media (min-width: 992px) { .main-content { padding: 40px; } }
    </style>
</head>
<body>

<div class="main-content">

    <!-- Flash -->
    <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
        <div class="flash-message flash-success"><i class="fas fa-circle-check"></i> <%= success_msg %></div>
    <% } %>
    <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
        <div class="flash-message flash-danger"><i class="fas fa-circle-exclamation"></i> <%= error_msg %></div>
    <% } %>

    <!-- Header -->
    <header class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="small mb-0">
                <a href="/admin/dashboard" class="text-decoration-none" style="color:#0F6E56;">
                    <i class="fa-solid fa-arrow-left me-1"></i> Dashboard
                </a>
            </p>
            <h1 class="h4 fw-bold mb-0 mt-1">Notifications</h1>
        </div>
        <a href="/auth/logout" class="bg-white p-2 rounded-3 border text-decoration-none">
            <i class="fa-solid fa-right-from-bracket text-danger"></i>
        </a>
    </header>

    <!-- Hero -->
    <div class="hero-card">
        <div>
            <h1><i class="fa-solid fa-bell me-2" style="opacity:0.8;"></i> Notification Centre</h1>
            <p>Send announcements to all users or personal messages to individual clients</p>
        </div>
        <div class="hero-icon"><i class="fa-solid fa-paper-plane"></i></div>
    </div>

    <div class="row g-4 mb-4">

        <!-- BROADCAST: all users -->
        <div class="col-12 col-lg-6">
            <div class="f-card">
                <div class="card-title">
                    <div class="card-title-icon icon-broadcast">
                        <i class="fa-solid fa-bullhorn"></i>
                    </div>
                    Broadcast Announcement
                </div>
                <p class="card-sub">
                    This message will be visible to <strong>all users</strong> in their notifications tab.
                    Use it for system updates, maintenance notices, promotions, or policy changes.
                </p>

                <form action="/admin/notifications/general" method="POST">
                    <div class="mb-3">
                        <label class="form-label">Notification Title</label>
                        <input type="text" class="form-control" name="title" required
                               placeholder="e.g. Scheduled Maintenance – 2 Jan 2026">
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Message</label>
                        <textarea class="form-control" name="message" required
                                  placeholder="Write your announcement here. Be clear and concise — users will see this in full."></textarea>
                    </div>

                    <!-- Preview of what users will see -->
                    <div style="background:#F4F8F7;border:1px solid #E8EFED;border-radius:14px;padding:14px 16px;margin-bottom:20px;">
                        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.6px;color:#64748B;margin-bottom:8px;">
                            Preview — how users will see it
                        </div>
                        <div style="display:flex;gap:12px;align-items:flex-start;">
                            <div style="width:36px;height:36px;border-radius:10px;background:#E1F5EE;color:#0F6E56;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="fa-solid fa-bullhorn"></i>
                            </div>
                            <div>
                                <div style="font-size:13px;font-weight:700;">📢 Your title here</div>
                                <div style="font-size:12px;color:#64748B;margin-top:2px;">Your message here...</div>
                                <div style="font-size:11px;color:#94a3b8;margin-top:4px;">Just now · Announcement</div>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn-send btn-broadcast">
                        <i class="fa-solid fa-bullhorn"></i> Send to All Users
                    </button>
                </form>
            </div>
        </div>

        <!-- PERSONAL: one user -->
        <div class="col-12 col-lg-6">
            <div class="f-card">
                <div class="card-title">
                    <div class="card-title-icon icon-personal">
                        <i class="fa-solid fa-user"></i>
                    </div>
                    Personal Message
                </div>
                <p class="card-sub">
                    Send a private message to a <strong>specific user</strong>.
                    Use this for KYC feedback, account alerts, support responses, or individual notices.
                </p>

                <form action="/admin/notifications/personal" method="POST">
                    <!-- User selector with search -->
                    <div class="mb-3">
                        <label class="form-label">Select User</label>
                        <input type="text" class="user-search" id="userSearch"
                               placeholder="🔍 Search by name or email..."
                               oninput="filterUsers(this.value)">
                        <select class="form-select user-select" name="user_id" id="userSelect"
                                size="5" required>
                            <% if (typeof users !== 'undefined' && users) { %>
                                <% users.forEach(u => { %>
                                    <option value="<%= u.id %>">
                                        <%= u.first_name %> <%= u.last_name %> — <%= u.email %>
                                    </option>
                                <% }) %>
                            <% } %>
                        </select>
                        <div style="font-size:11px;color:#64748B;margin-top:6px;">
                            Scroll and click a user to select them
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Message Title</label>
                        <input type="text" class="form-control" name="title" required
                               placeholder="e.g. Your KYC has been approved">
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Message</label>
                        <textarea class="form-control" name="message" required
                                  placeholder="Write a clear message to this user. They'll see exactly what you type here."></textarea>
                    </div>

                    <button type="submit" class="btn-send btn-personal">
                        <i class="fa-solid fa-paper-plane"></i> Send Personal Message
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- HISTORY -->
    <div class="f-card">
        <div class="section-label">
            <i class="fa-solid fa-clock-rotate-left me-2"></i>
            Recently Sent (last 50)
        </div>

        <%
            const notifs = (typeof notifications !== 'undefined' && notifications) ? notifications : [];
        %>

        <% if (notifs.length > 0) { %>
            <% notifs.forEach(n => { %>
            <div class="notif-row">
                <div class="notif-row-icon <%= n.type === 'personal' ? 'row-icon-personal' : 'row-icon-general' %>">
                    <i class="fa-solid <%= n.type === 'personal' ? 'fa-user' : 'fa-bullhorn' %>"></i>
                </div>
                <div class="notif-row-body">
                    <div class="notif-row-title"><%= n.title %></div>
                    <div class="notif-row-message"><%= n.message %></div>
                    <div class="notif-row-meta">
                        <span class="notif-badge <%= n.type === 'personal' ? 'nb-personal' : 'nb-general' %>">
                            <%= n.type === 'personal' ? 'Personal' : 'Broadcast' %>
                        </span>
                        <span>→</span>
                        <span>
                            <% if (n.type === 'personal' && n.recipient_name) { %>
                                <i class="fa-solid fa-user"></i> <%= n.recipient_name %>
                            <% } else { %>
                                <i class="fa-solid fa-users"></i> All Users
                            <% } %>
                        </span>
                        <span>·</span>
                        <span><i class="fa-regular fa-clock"></i>
                            <%= new Date(n.created_at).toLocaleString('en-US',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                        </span>
                    </div>
                </div>
                <form action="/admin/notifications/<%= n.id %>/delete" method="POST" style="flex-shrink:0;"
                      onsubmit="return confirm('Delete this notification?')">
                    <button type="submit" class="btn-delete" title="Delete">
                        <i class="fa-solid fa-trash"></i>
                    </button>
                </form>
            </div>
            <% }) %>
        <% } else { %>
            <div class="empty-mini">
                <i class="fa-solid fa-paper-plane"></i>
                <span style="font-size:14px;font-weight:600;">No notifications sent yet</span>
            </div>
        <% } %>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Live search through user select options
    function filterUsers(query) {
        const q    = query.toLowerCase();
        const opts = document.getElementById('userSelect').options;
        for (let i = 0; i < opts.length; i++) {
            opts[i].style.display = opts[i].text.toLowerCase().includes(q) ? '' : 'none';
        }
    }
</script>
</body>
</html>
