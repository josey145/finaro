<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>403 - Restricted Area | VaultBank</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --primary: #0F6E56;
            --bg-body: #F4F8F7;
            --text-main: #0D1B16;
            --text-muted: #64748B;
            --card-radius: 24px;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .error-card {
            background: #ffffff;
            max-width: 450px;
            width: 100%;
            padding: 40px;
            border-radius: var(--card-radius);
            box-shadow: 0 15px 35px rgba(13, 27, 22, 0.05);
            text-align: center;
            border: 1px solid #E8EFED;
        }

        .icon-shield {
            width: 80px;
            height: 80px;
            background: #FEE2E2; /* Soft Red */
            color: #DC2626;     /* Bright Red */
            border-radius: 20px;
            display: grid;
            place-items: center;
            font-size: 32px;
            margin: 0 auto 25px;
            position: relative;
        }

        .lock-badge {
            position: absolute;
            bottom: -5px;
            right: -5px;
            background: var(--text-main);
            color: white;
            width: 28px;
            height: 28px;
            border-radius: 8px;
            font-size: 14px;
            display: grid;
            place-items: center;
            border: 3px solid #fff;
        }

        h1 {
            font-weight: 800;
            font-size: 48px;
            margin-bottom: 5px;
            letter-spacing: -2px;
            color: var(--text-main);
        }

        h2 {
            font-weight: 700;
            font-size: 20px;
            margin-bottom: 15px;
        }

        p {
            color: var(--text-muted);
            font-size: 15px;
            line-height: 1.6;
            margin-bottom: 30px;
        }

        .btn-action {
            background: var(--text-main);
            color: white;
            padding: 14px 24px;
            border-radius: 14px;
            font-weight: 700;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.3s;
            border: none;
            width: 100%;
        }

        .btn-action:hover {
            background: var(--primary);
            color: white;
            transform: translateY(-2px);
        }

        .btn-secondary-link {
            display: inline-block;
            margin-top: 20px;
            font-weight: 700;
            font-size: 13px;
            color: var(--primary);
            text-decoration: none;
            opacity: 0.8;
        }

        .btn-secondary-link:hover { opacity: 1; }

    </style>
</head>
<body>

    <div class="error-card">
        <div class="icon-shield">
            <i class="fa-solid fa-user-shield"></i>
            <div class="lock-badge">
                <i class="fa-solid fa-lock"></i>
            </div>
        </div>

        <h1>403</h1>
        <h2>Access Restricted</h2>
        <p>
            <%= (typeof message !== 'undefined' && message) ? message : 'Your current account level does not have permission to view this secure resource.' %>
        </p>

        <a href="/" class="btn-action">
            <i class="fa-solid fa-arrow-left"></i>
            Back to Dashboard
        </a>

        <a href="/user/kyc" class="btn-secondary-link">
            Upgrade Account Security <i class="fa-solid fa-chevron-right ms-1" style="font-size: 10px;"></i>
        </a>
    </div>

</body>
</html>