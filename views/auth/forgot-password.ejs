<!DOCTYPE html>
<html lang="<%= lang || 'en' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - Ambrato Bank</title>
    <style>
        :root {
            --primary: #0d9488;
            --primary-dark: #0f766e;
            --bg-start: #f0fdfa;
            --bg-end: #e0f2fe;
            --card: #ffffff;
            --text: #1e293b;
            --muted: #64748b;
            --border: #f1f5f9;
            --danger-bg: #fef2f2;
            --danger-text: #ef4444;
            --success-bg: #f0fdf4;
            --success-text: #22c55e;
            --info-bg: #eff6ff;
            --info-text: #3b82f6;
        }

        [data-theme="dark"] {
            --bg-start: #0f172a;
            --bg-end: #1e293b;
            --card: #1e293b;
            --text: #f1f5f9;
            --muted: #94a3b8;
            --border: #334155;
            --danger-bg: rgba(239, 68, 68, 0.15);
            --danger-text: #ef4444;
            --success-bg: rgba(34, 197, 94, 0.15);
            --success-text: #22c55e;
            --info-bg: rgba(59, 130, 246, 0.15);
            --info-text: #3b82f6;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, var(--bg-start) 0%, var(--bg-end) 100%);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .box {
            background: var(--card);
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 400px;
        }

        h1 { color: var(--primary); text-align: center; margin-bottom: 10px; font-size: 24px; }
        p.subtitle { color: var(--muted); text-align: center; margin-bottom: 30px; font-size: 14px; }

        input {
            width: 100%;
            padding: 14px;
            margin-bottom: 16px;
            border: 2px solid var(--border);
            border-radius: 10px;
            font-size: 15px;
            background: var(--card);
            color: var(--text);
        }

        input:focus {
            outline: none;
            border-color: var(--primary);
        }

        button {
            width: 100%;
            padding: 14px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
        }

        button:hover { background: var(--primary-dark); }

        .links {
            text-align: center;
            margin-top: 20px;
        }

        .links a {
            color: var(--primary);
            text-decoration: none;
        }

        .alert {
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 16px;
            font-size: 14px;
        }

        .alert-danger { background: var(--danger-bg); color: var(--danger-text); }
        .alert-success { background: var(--success-bg); color: var(--success-text); }
        .alert-info { background: var(--info-bg); color: var(--info-text); }
    </style>
</head>
<body data-theme="<%= theme || 'light' %>">

    <div class="box">
        <h1>🔑 Reset Password</h1>
        <p class="subtitle">Enter your email to receive a reset link</p>
        
        <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
            <div class="alert alert-danger"><%= error_msg %></div>
        <% } %>
        
        <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success"><%= success_msg %></div>
        <% } %>
        
        <% if (typeof info_msg !== 'undefined' && info_msg && info_msg.length > 0) { %>
            <div class="alert alert-info"><%= info_msg %></div>
        <% } %>

        <form action="/auth/forgot-password" method="POST">
            <input type="email" name="email" placeholder="Email" required>
            <button type="submit">Send Reset Link</button>
        </form>
        
        <div class="links">
            <p><a href="/auth/login">← Back to Login</a></p>
        </div>
    </div>

</body>
</html>