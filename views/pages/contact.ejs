<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Contact Us | Ambrato</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 rx=%2220%22 fill=%22%230F6E56%22></rect><path d=%22M30 40 L50 60 L70 40%22 stroke=%22white%22 stroke-width=%228%22 fill=%2２none%２ stroke-linecap=%２round%２/></svg>">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="../../css/index.css"/>

    <style>
        .page-banner {
            padding: 140px 6% 80px;
            text-align: center;
            background: radial-gradient(circle at top, #F2FAF8 0%, var(--bg) 50%);
        }
        .page-banner h1 {
            font-size: clamp(32px, 5vw, 56px);
            font-weight: 700;
            margin-bottom: 16px;
            color: var(--text-dark);
        }
        .page-banner p {
            color: var(--text-light);
            font-size: 18px;
            max-width: 600px;
            margin: 0 auto;
        }

        .contact-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
            max-width: 1000px;
            margin: 0 auto;
        }
        .contact-card {
            padding: 40px;
            border-radius: var(--radius);
            border: 1px solid var(--border);
            background: var(--card-bg, white);
            text-align: center;
            transition: all 0.3s;
        }
        .contact-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px var(--shadow);
            border-color: var(--accent);
        }
        .contact-card i {
            font-size: 40px;
            color: var(--primary);
            margin-bottom: 20px;
        }
        .contact-card h3 {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 8px;
            color: var(--text-dark);
        }
        .contact-card .info {
            font-size: 16px;
            font-weight: 600;
            color: var(--accent);
            margin-bottom: 8px;
        }
        .contact-card p {
            color: var(--text-light);
            font-size: 14px;
        }

        .dept-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            max-width: 1000px;
            margin: 0 auto;
        }
        .dept-card {
            padding: 28px;
            border-radius: var(--radius);
            border: 1px solid var(--border);
            background: var(--card-bg, white);
            display: flex;
            align-items: flex-start;
            gap: 16px;
            transition: all 0.3s;
        }
        .dept-card:hover {
            border-color: var(--accent);
            box-shadow: 0 8px 25px var(--shadow);
        }
        .dept-card i {
            font-size: 24px;
            color: var(--primary);
            margin-top: 4px;
        }
        .dept-card h4 {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 4px;
            color: var(--text-dark);
        }
        .dept-card .email {
            font-size: 13px;
            color: var(--accent);
            font-weight: 600;
            margin-bottom: 6px;
        }
        .dept-card p {
            font-size: 13px;
            color: var(--text-light);
            line-height: 1.5;
        }

        .section-header {
            text-align: center;
            max-width: 700px;
            margin: 0 auto 60px;
        }
        .section-header h2 {
            font-size: clamp(1.8rem, 3vw, 2.5rem);
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 16px;
        }
        .section-header p {
            color: var(--text-light);
            font-size: 1.1rem;
        }

        [data-theme="dark"] .page-banner {
            background: radial-gradient(circle at top, #0f2e24 0%, var(--bg) 60%);
        }

        @media (max-width: 768px) {
            .page-banner { padding: 120px 20px 60px; }
        }
    </style>
<base target="_blank">
</head>
<body>
    <%- include('../partials/nav') %>

    <section class="page-banner">
        <h1 data-aos="fade-up" data-aos-duration="1000">Get in <span style="color: var(--accent);">Touch</span></h1>
        <p data-aos="fade-up" data-aos-delay="200">Have questions about Ambrato? We'd love to hear from you.</p>
    </section>

    <section>
        <div class="section-header" data-aos="fade-up">
            <h2>Contact Methods</h2>
            <p>Reach out through your preferred channel.</p>
        </div>
        <div class="contact-grid">
            <div class="contact-card" data-aos="fade-up" data-aos-delay="100">
                <i class="fas fa-envelope"></i>
                <h3>Email</h3>
                <div class="info">ambrato.team@ambrato.com.ng</div>
                <p>For general inquiries and support</p>
            </div>
            <div class="contact-card" data-aos="fade-up" data-aos-delay="200">
                <i class="fas fa-comments"></i>
                <h3>Live Chat</h3>
                <div class="info">Available during business hours</div>
                <p>Get instant answers from our team</p>
            </div>
            <div class="contact-card" data-aos="fade-up" data-aos-delay="300">
                <i class="fas fa-phone"></i>
                <h3>Phone</h3>
                <div class="info">Coming soon</div>
                <p>Phone support launching with full release</p>
            </div>
        </div>
    </section>

    <section style="background: var(--surface);">
        <div class="section-header" data-aos="fade-up">
            <h2>Departments</h2>
            <p>Reach the right team for your needs.</p>
        </div>
        <div class="dept-grid">
            <div class="dept-card" data-aos="fade-up" data-aos-delay="100">
                <i class="fas fa-headset"></i>
                <div>
                    <h4>Customer Support</h4>
                    <div class="email">ambrato.team@ambrato.com.ng</div>
                    <p>Help with accounts, transactions, and technical issues</p>
                </div>
            </div>
            <div class="dept-card" data-aos="fade-up" data-aos-delay="150">
                <i class="fas fa-briefcase"></i>
                <div>
                    <h4>Business Inquiries</h4>
                    <div class="email">ambrato.team@ambrato.com.ng</div>
                    <p>Partnerships, enterprise solutions, and API access</p>
                </div>
            </div>
            <div class="dept-card" data-aos="fade-up" data-aos-delay="200">
                <i class="fas fa-newspaper"></i>
                <div>
                    <h4>Press & Media</h4>
                    <div class="email">ambrato.team@ambrato.com.ng</div>
                    <p>Media kits, interviews, and press releases</p>
                </div>
            </div>
            <div class="dept-card" data-aos="fade-up" data-aos-delay="250">
                <i class="fas fa-shield-halved"></i>
                <div>
                    <h4>Security</h4>
                    <div class="email">ambrato.team@ambrato.com.ng</div>
                    <p>Report vulnerabilities or security concerns</p>
                </div>
            </div>
        </div>
    </section>

    <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark, #0f766e) 100%); color: white; text-align: center; padding: 100px 6%;">
        <h2 data-aos="fade-up" style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; margin-bottom: 16px;">Ready to join us?</h2>
        <p data-aos="fade-up" data-aos-delay="100" style="font-size: 1.1rem; opacity: 0.9; max-width: 600px; margin: 0 auto 40px;">Be among the first to experience Ambrato.</p>
        <div data-aos="fade-up" data-aos-delay="200">
            <a href="/auth/register" class="btn-nav" style="padding: 18px 40px; font-size: 18px; text-decoration: none; display: inline-flex; align-items: center; gap: 10px;">
                <i class="fas fa-rocket"></i> Join Early Access
            </a>
        </div>
    </section>

    <%- include('../partials/footer') %>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 800, once: true, offset: 100, easing: 'ease-out-cubic' });
    </script>
</body>
</html>