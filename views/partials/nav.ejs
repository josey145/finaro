<%
  const _navTheme = typeof theme !== 'undefined' ? theme
                  : typeof _theme !== 'undefined' ? _theme
                  : 'light';
  const _navLang  = typeof lang !== 'undefined' ? lang
                  : typeof _lang !== 'undefined' ? _lang
                  : 'en';
  const _navPage  = typeof page !== 'undefined' ? page : '';

  const _navItems = (typeof navItems !== 'undefined' && navItems) ? navItems : [
      { id: 'products',  label: 'Products',  href: '/'          },
      { id: 'solutions', label: 'Solutions', href: '/solutions'  },
      { id: 'about',     label: 'About Us',  href: '/about'      },
      { id: 'pricing',   label: 'Pricing',   href: '/pricing'    },
      { id: 'policy',    label: 'Policy',    href: '/policy'     },
  ];

  const languages = [
      { code: 'en',    label: 'EN', flag: '🇺🇸', name: 'English'   },
      { code: 'fr',    label: 'FR', flag: '🇫🇷', name: 'Français'  },
      { code: 'de',    label: 'DE', flag: '🇩🇪', name: 'Deutsch'   },
      { code: 'es',    label: 'ES', flag: '🇪🇸', name: 'Español'   },
      { code: 'zh-CN', label: 'ZH', flag: '🇨🇳', name: '中文'      },
      { code: 'ar',    label: 'AR', flag: '🇸🇦', name: 'العربية'   },
      { code: 'ja',    label: 'JA', flag: '🇯🇵', name: '日本語'    },
      { code: 'pt',    label: 'PT', flag: '🇧🇷', name: 'Português' },
  ];

  const currentLang = languages.find(l => l.code === _navLang) || languages[0];
%>

<!-- FinoraConfig: must be defined before navbar JS runs -->
<script>
    window.FinoraConfig = {
        navLang:    '<%= _navLang %>',
        navTheme:   '<%= _navTheme %>',
        isLoggedIn: <%= (typeof user !== 'undefined' && user && user.id) ? 'true' : 'false' %>
    };
</script>

<!-- Google Translate hidden element -->
<div id="google_translate_element" style="display:none;"></div>

<style>
/* ── Hide Google Translate toolbar ── */
.goog-te-banner-frame,
.skiptranslate { display: none !important; }
body { top: 0 !important; position: static !important; }
#google_translate_element * { display: none; }

/* ── CSS VARIABLES ── */
nav {
    --nav-bg:      var(--bg-card, rgba(255,255,255,0.97));
    --nav-border:  var(--border, rgba(15,110,86,0.08));
    --nav-text:    var(--text-muted, #64748B);
    --toggle-bg:   var(--bg-input, #F4F8F7);
    --dropdown-bg: var(--bg-card, #ffffff);
}
[data-theme="dark"] nav,
[data-theme="dark"] {
    --nav-bg:      rgba(15,23,42,0.97);
    --nav-border:  #334155;
    --nav-text:    #94a3b8;
    --toggle-bg:   #1e293b;
    --dropdown-bg: #1e293b;
}
@media (prefers-color-scheme: dark) {
    [data-theme="auto"] nav,
    [data-theme="auto"] {
        --nav-bg:      rgba(15,23,42,0.97);
        --nav-border:  #334155;
        --nav-text:    #94a3b8;
        --toggle-bg:   #1e293b;
        --dropdown-bg: #1e293b;
    }
}

/* ── NAV BASE ── */
.fnav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    height: 68px;
    background: var(--nav-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--nav-border);
    position: sticky;
    top: 0;
    z-index: 1000;
    transition: background 0.3s;
}

/* ── LOGO ── */
.fnav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #0F6E56;
    font-weight: 800;
    font-size: 18px;
    font-family: 'Plus Jakarta Sans', 'Sora', sans-serif;
    flex-shrink: 0;
    letter-spacing: -0.3px;
}
.fnav-logo-box {
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, #0F6E56, #1D9E75);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 16px;
    flex-shrink: 0;
}

/* ── DESKTOP NAV LINKS ── */
.fnav-links {
    display: flex;
    align-items: center;
    gap: 2px;
    list-style: none;
    margin: 0;
    padding: 0;
}
.fnav-links li a {
    padding: 8px 14px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    color: var(--nav-text);
    text-decoration: none;
    transition: all 0.2s;
    white-space: nowrap;
    font-family: 'Plus Jakarta Sans', sans-serif;
}
.fnav-links li a:hover,
.fnav-links li a.active {
    color: #0F6E56;
    background: rgba(15,110,86,0.08);
}

/* ── NAV ACTIONS ── */
.fnav-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
}

/* ── THEME TOGGLE ── */
.fnav-theme-btn {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    border: 1.5px solid var(--nav-border);
    background: var(--toggle-bg);
    color: var(--nav-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    transition: all 0.2s;
    flex-shrink: 0;
}
.fnav-theme-btn:hover {
    border-color: #0F6E56;
    color: #0F6E56;
    background: rgba(15,110,86,0.08);
}

/* ── LANGUAGE DROPDOWN ── */
.fnav-lang-dd { position: relative; flex-shrink: 0; }

.fnav-lang-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0 12px;
    height: 38px;
    border-radius: 10px;
    border: 1.5px solid var(--nav-border);
    background: var(--toggle-bg);
    color: var(--nav-text);
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Plus Jakarta Sans', sans-serif;
    white-space: nowrap;
}
.fnav-lang-btn:hover {
    border-color: #0F6E56;
    color: #0F6E56;
    background: rgba(15,110,86,0.08);
}
.fnav-lang-btn .fnav-chevron {
    font-size: 10px;
    transition: transform 0.2s;
    margin-left: 2px;
}
.fnav-lang-btn.open .fnav-chevron { transform: rotate(180deg); }

.fnav-lang-menu {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--dropdown-bg);
    border: 1px solid var(--nav-border);
    border-radius: 14px;
    padding: 8px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.12);
    min-width: 165px;
    z-index: 2000;
}
.fnav-lang-menu.open { display: block; }

.fnav-lang-opt {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    color: var(--nav-text);
    cursor: pointer;
    transition: all 0.15s;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
    font-family: 'Plus Jakarta Sans', sans-serif;
}
.fnav-lang-opt:hover  { background: rgba(15,110,86,0.08); color: #0F6E56; }
.fnav-lang-opt.active { background: #0F6E56; color: white; }
.fnav-lang-opt .opt-flag { font-size: 17px; }
.fnav-lang-opt .opt-name { flex: 1; }
.fnav-lang-opt .opt-code { font-size: 11px; opacity: 0.7; }

/* ── OPEN ACCOUNT BUTTON ── */
.fnav-cta {
    padding: 0 18px;
    height: 38px;
    background: linear-gradient(135deg, #0F6E56, #1D9E75);
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    font-family: 'Plus Jakarta Sans', sans-serif;
    transition: all 0.2s;
    white-space: nowrap;
    text-decoration: none;
    display: flex;
    align-items: center;
}
.fnav-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(15,110,86,0.3);
    color: white;
}

/* ── HAMBURGER ── */
.fnav-hamburger {
    display: none;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    border: 1.5px solid var(--nav-border);
    background: var(--toggle-bg);
    color: var(--nav-text);
    align-items: center;
    justify-content: center;
    font-size: 17px;
    cursor: pointer;
    flex-shrink: 0;
    transition: all 0.2s;
}
.fnav-hamburger:hover {
    border-color: #0F6E56;
    color: #0F6E56;
}

/* ── MOBILE DRAWER OVERLAY ── */
.fnav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 1998;
    opacity: 0;
    transition: opacity 0.3s;
}
.fnav-overlay.show {
    display: block;
    opacity: 1;
}

/* ── MOBILE DRAWER ── */
.fnav-drawer {
    position: fixed;
    top: 0;
    right: -320px;
    width: 300px;
    max-width: 85vw;
    height: 100vh;
    background: var(--dropdown-bg);
    border-left: 1px solid var(--nav-border);
    z-index: 1999;
    display: flex;
    flex-direction: column;
    padding: 24px 20px;
    box-shadow: -10px 0 40px rgba(0,0,0,0.12);
    transition: right 0.35s cubic-bezier(0.4,0,0.2,1);
    overflow-y: auto;
}
.fnav-drawer.open { right: 0; }

.fnav-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    flex-shrink: 0;
}
.fnav-drawer-close {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: 1.5px solid var(--nav-border);
    background: var(--toggle-bg);
    color: var(--nav-text);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    cursor: pointer;
}

.fnav-drawer-links {
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
    flex-shrink: 0;
}
.fnav-drawer-links li { margin-bottom: 4px; }
.fnav-drawer-links li a {
    display: block;
    padding: 12px 14px;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 600;
    color: var(--nav-text);
    text-decoration: none;
    transition: all 0.2s;
    font-family: 'Plus Jakarta Sans', sans-serif;
}
.fnav-drawer-links li a:hover,
.fnav-drawer-links li a.active {
    color: #0F6E56;
    background: rgba(15,110,86,0.08);
}

.fnav-drawer-divider {
    border: none;
    border-top: 1px solid var(--nav-border);
    margin: 12px 0;
    flex-shrink: 0;
}

.fnav-drawer-controls {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    margin-bottom: 16px;
}
.fnav-drawer-controls .fnav-theme-btn { flex: 0 0 42px; width: 42px; height: 42px; }
.fnav-drawer-controls .fnav-lang-dd   { flex: 1; }
.fnav-drawer-controls .fnav-lang-btn  { width: 100%; justify-content: center; }
.fnav-drawer-controls .fnav-lang-menu {
    right: auto;
    left: 0;
}

.fnav-drawer-cta { flex-shrink: 0; }
.fnav-drawer-cta .fnav-cta {
    width: 100%;
    justify-content: center;
    height: 44px;
    font-size: 14px;
    border-radius: 12px;
}

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
    .fnav { padding: 0 20px; }
    .fnav-links  { display: none; }
    .fnav-actions .fnav-theme-btn,
    .fnav-actions .fnav-lang-dd,
    .fnav-actions .fnav-cta { display: none; }
    .fnav-hamburger { display: flex; }
}

/* ── RTL ── */
[dir="rtl"] .fnav          { direction: rtl; }
[dir="rtl"] .fnav-lang-menu { right: auto; left: 0; }
[dir="rtl"] .fnav-drawer   { right: auto; left: -320px; border-left: none; border-right: 1px solid var(--nav-border); }
[dir="rtl"] .fnav-drawer.open { left: 0; }
</style>

<!-- ════════════ NAV HTML ════════════ -->
<nav class="fnav" role="navigation" aria-label="Main navigation">

