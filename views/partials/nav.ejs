<!-- Google Translate -->
<script>
function googleTranslateElementInit() {
    new google.translate.TranslateElement({ pageLanguage: 'en', autoDisplay: false }, 'google_translate_element');
}
</script>
<script src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit" async defer></script>

<script>
(function () {
    'use strict';

    /* ── Safety guard: ensure FinoraConfig always exists ── */
    if (!window.FinoraConfig) {
        window.FinoraConfig = { navLang: 'en', navTheme: 'light', isLoggedIn: false };
    }

    var LANG_KEY  = 'finora_lang';
    var THEME_KEY = 'finora_theme';

    /* ── GOOGLE TRANSLATE ── */
    function googleTranslateTo(code) {
        if (code === 'en') {
            ['', window.location.hostname].forEach(function (domain) {
                var d = new Date(); d.setTime(d.getTime() - 86400000);
                var base = 'googtrans=; expires=' + d.toUTCString() + '; path=/';
                document.cookie = domain ? base + '; domain=' + domain : base;
            });
            location.reload();
            return;
        }
        var val = '/en/' + code;
        document.cookie = 'googtrans=' + val + '; path=/';
        document.cookie = 'googtrans=' + val + '; domain=' + window.location.hostname + '; path=/';
        (function trySelect() {
            var sel = document.querySelector('.goog-te-combo');
            if (sel) { sel.value = code; sel.dispatchEvent(new Event('change')); }
            else      { setTimeout(trySelect, 350); }
        })();
    }

    /* ── LANGUAGE META ── */
    var langMeta = {
        'en':    { flag: '🇺🇸', label: 'EN' },
        'fr':    { flag: '🇫🇷', label: 'FR' },
        'de':    { flag: '🇩🇪', label: 'DE' },
        'es':    { flag: '🇪🇸', label: 'ES' },
        'zh-CN': { flag: '🇨🇳', label: 'ZH' },
        'ar':    { flag: '🇸🇦', label: 'AR' },
        'ja':    { flag: '🇯🇵', label: 'JA' },
        'pt':    { flag: '🇧🇷', label: 'PT' },
    };

    /* ── SET LANGUAGE ── */
    window.fnavSetLang = function (code, flag, label) {
        localStorage.setItem(LANG_KEY, code);

        ['desktop', 'mobile'].forEach(function (side) {
            var f = document.getElementById('fnav-lang-flag-'  + side);
            var l = document.getElementById('fnav-lang-label-' + side);
            if (f) f.textContent = flag;
            if (l) l.textContent = label;
        });

        document.querySelectorAll('.fnav-lang-opt').forEach(function (b) {
            b.classList.toggle('active', b.getAttribute('data-lang') === code);
        });

        document.documentElement.setAttribute('dir', code === 'ar' ? 'rtl' : 'ltr');
        fnavCloseLangMenus();
        googleTranslateTo(code);

        if (window.FinoraConfig.isLoggedIn) {
            fetch('/user/settings/language', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ lang: code })
            }).catch(function () {});
        }
    };

    /* ── ATTACH CLICK TO ALL LANG OPTIONS ── */
    document.querySelectorAll('.fnav-lang-opt').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
            e.stopPropagation();
            var code = btn.getAttribute('data-lang');
            var meta = langMeta[code] || { flag: '🌐', label: code.toUpperCase() };
            window.fnavSetLang(code, meta.flag, meta.label);
        });
    });

    /* ── GET SAVED LANG ── */
    function getSavedLang() {
        try {
            var cookie = document.cookie.split(';').find(function (c) {
                return c.trim().startsWith('googtrans=');
            });
            if (cookie) {
                var p = cookie.trim().split('/');
                if (p.length === 3 && p[2]) return p[2];
            }
        } catch (e) {}
        return localStorage.getItem(LANG_KEY) || (window.FinoraConfig && window.FinoraConfig.navLang) || 'en';
    }

    /* ── INIT LANGUAGE UI ── */
    var initLang = getSavedLang();
    if (initLang && initLang !== 'en') {
        var m = langMeta[initLang];
        if (m) {
            ['desktop', 'mobile'].forEach(function (side) {
                var f = document.getElementById('fnav-lang-flag-'  + side);
                var l = document.getElementById('fnav-lang-label-' + side);
                if (f) f.textContent = m.flag;
                if (l) l.textContent = m.label;
            });
            document.querySelectorAll('.fnav-lang-opt').forEach(function (b) {
                b.classList.toggle('active', b.getAttribute('data-lang') === initLang);
            });
            if (initLang === 'ar') document.documentElement.setAttribute('dir', 'rtl');
        }
    }

    /* ── THEME ── */
    var savedTheme  = localStorage.getItem(THEME_KEY) || (window.FinoraConfig && window.FinoraConfig.navTheme) || 'light';
    var activeTheme = document.documentElement.getAttribute('data-theme') || savedTheme;

    function applyTheme(t) {
        document.documentElement.setAttribute('data-theme', t);
        localStorage.setItem(THEME_KEY, t);
        var icon = t === 'dark' ? 'fa-sun' : 'fa-moon';
        ['desktop', 'mobile'].forEach(function (side) {
            var el = document.getElementById('fnav-theme-icon-' + side);
            if (el) el.className = 'fas ' + icon;
        });
    }

    applyTheme(activeTheme);

    function toggleTheme() {
        var next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        applyTheme(next);
        if (window.FinoraConfig && window.FinoraConfig.isLoggedIn) {
            fetch('/user/settings/theme', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ theme: next })
            }).catch(function () {});
        }
    }

    var td = document.getElementById('fnav-theme-desktop');
    var tm = document.getElementById('fnav-theme-mobile');
    if (td) td.addEventListener('click', toggleTheme);
    if (tm) tm.addEventListener('click', toggleTheme);

    /* ── LANGUAGE DROPDOWNS ── */
    function fnavCloseLangMenus() {
        document.querySelectorAll('.fnav-lang-menu').forEach(function (m) { m.classList.remove('open'); });
        document.querySelectorAll('.fnav-lang-btn').forEach(function (b)  { b.classList.remove('open'); b.setAttribute('aria-expanded', 'false'); });
    }
    window.fnavCloseLangMenus = fnavCloseLangMenus;

    function setupLangDropdown(btnId, menuId) {
        var btn  = document.getElementById(btnId);
        var menu = document.getElementById(menuId);
        if (!btn || !menu) return;
        btn.addEventListener('click', function (e) {
            e.stopPropagation();
            var isOpen = menu.classList.contains('open');
            fnavCloseLangMenus();
            if (!isOpen) {
                menu.classList.add('open');
                btn.classList.add('open');
                btn.setAttribute('aria-expanded', 'true');
            }
        });
    }

    setupLangDropdown('fnav-lang-btn-desktop', 'fnav-lang-menu-desktop');
    setupLangDropdown('fnav-lang-btn-mobile',  'fnav-lang-menu-mobile');

    document.addEventListener('click', fnavCloseLangMenus);

    /* ── MOBILE DRAWER ── */
    var drawer   = document.getElementById('fnav-drawer');
    var overlay  = document.getElementById('fnav-overlay');
    var openBtn  = document.getElementById('fnav-open');
    var closeBtn = document.getElementById('fnav-close');

    function openDrawer() {
        if (drawer)  drawer.classList.add('open');
        if (overlay) overlay.classList.add('show');
        document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
        if (drawer)  drawer.classList.remove('open');
        if (overlay) overlay.classList.remove('show');
        document.body.style.overflow = '';
        fnavCloseLangMenus();
    }

    if (openBtn)  openBtn.addEventListener('click', openDrawer);
    if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
    if (overlay)  overlay.addEventListener('click', closeDrawer);

    if (drawer) {
        drawer.querySelectorAll('a').forEach(function (a) {
            a.addEventListener('click', closeDrawer);
        });
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeDrawer();
    });

})();
</script>
