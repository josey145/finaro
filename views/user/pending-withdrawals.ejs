<!DOCTYPE html>
<html lang="<%= lang %>" data-theme="<%= theme %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pending Withdrawals - Ambrato Bank</title>
    <script>document.documentElement.setAttribute('data-theme','<%= theme %>');</script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root { --primary:#0F6E56; --bg-body:#F4F8F7; --bg-card:#fff; --text-main:#0D1B16; --text-muted:#64748B; --border:#E8EFED; --warning:#f59e0b; }
        [data-theme="dark"] { --bg-body:#0f172a; --bg-card:#1e293b; --text-main:#f1f5f9; --text-muted:#94a3b8; --border:#334155; }
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'Plus Jakarta Sans',sans-serif; background:var(--bg-body); color:var(--text-main); padding-bottom:90px; }
        .main-content { padding:20px; max-width:760px; margin:0 auto; }
        .header-card { background:linear-gradient(135deg,#0F6E56,#1D9E75); border-radius:24px; padding:28px 32px; color:white; margin-bottom:20px; box-shadow:0 15px 35px rgba(15,110,86,.3); }
        .header-card h1 { font-size:1.5rem; font-weight:800; }
        .header-card p  { font-size:13px; opacity:.85; margin-top:4px; }
        .f-card { background:var(--bg-card); border-radius:20px; padding:20px 24px; border:1px solid var(--border); margin-bottom:16px; box-shadow:0 4px 20px rgba(15,110,86,.05); }
        .step-bar { display:flex; gap:4px; margin:10px 0 6px; }
        .step-dot { height:6px; border-radius:3px; flex:1; background:var(--border); transition:background .2s; }
        .step-dot.done { background:#22c55e; }
        .step-dot.active { background:#f59e0b; }
        .btn-resume { background:#0F6E56; color:white; padding:10px 20px; border-radius:12px; font-size:13px; font-weight:700; text-decoration:none; display:inline-flex; align-items:center; gap:6px; border:none; cursor:pointer; }
        .btn-cancel { background:transparent; color:#ef4444; padding:10px 16px; border-radius:12px; font-size:13px; font-weight:700; border:1.5px solid #ef4444; cursor:pointer; }
        .otp-notice { background:#fffbeb; border:1px solid #fde68a; border-radius:12px; padding:12px 16px; font-size:12px; color:#92400e; margin-top:10px; display:flex; align-items:flex-start; gap:8px; }
        .contact-btn { background:#f59e0b; color:white; padding:8px 16px; border-radius:10px; font-size:12px; font-weight:700; text-decoration:none; display:inline-flex; align-items:center; gap:4px; margin-top:8px; }
        .empty-state { text-align:center; padding:60px 20px; color:var(--text-muted); }
        .mobile-nav { position:fixed; bottom:0; left:0; width:100%; background:rgba(255,255,255,.95); backdrop-filter:blur(10px); border-top:1px solid var(--border); display:flex; justify-content:space-around; padding:10px 0 25px; z-index:1000; }
        .nav-item { text-align:center; color:var(--text-muted); text-decoration:none; font-size:10px; font-weight:700; }
        .nav-item i { font-size:20px; margin-bottom:4px; display:block; }
        @media(min-width:992px){ .mobile-nav{display:none;} body{padding-bottom:0;} .main-content{padding:40px;} }
    </style>
</head>
<body>
<div class="main-content">

    <div class="header-card">
        <div class="mb-1">
            <a href="/user/transactions" class="text-white text-decoration-none opacity-75" style="font-size:13px;">
                <i class="fa-solid fa-chevron-left me-1"></i> Back to Transactions
            </a>
        </div>
        <h1><i class="fa-solid fa-clock me-2"></i>Pending Withdrawals</h1>
        <p>Withdrawals that need your attention to complete</p>
    </div>

    <% if (typeof pendingWithdrawals !== 'undefined' && pendingWithdrawals.length > 0) { %>
        <% pendingWithdrawals.forEach(function(tx) { %>
        <div class="f-card">

            <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
                <div>
                    <div style="font-size:13px; color:var(--text-muted); font-weight:600;">Transaction #<%= tx.id %></div>
                    <div style="font-size:1.3rem; font-weight:800; color:var(--primary); margin-top:2px;"><%= tx.displayAmount %></div>
                    <div style="font-size:12px; color:var(--text-muted); margin-top:2px;">
                        To: <%= tx.recipient_account || '—' %>
                    </div>
                </div>
                <span style="background:#fffbeb;color:#b45309;padding:4px 12px;border-radius:20px;font-size:11px;font-weight:700;">
                    <i class="fa-solid fa-clock me-1"></i> Pending
                </span>
            </div>

            <%# Step progress bar %>
            <div style="font-size:11px; color:var(--text-muted); font-weight:700; text-transform:uppercase; letter-spacing:.5px; margin-bottom:4px;">
                Step <%= tx.completedSteps %> of <%= tx.totalSteps %> completed
            </div>
            <div class="step-bar">
                <% if (tx.steps && tx.steps.length > 0) { %>
                    <% tx.steps.forEach(function(step, i) { %>
                    <div class="step-dot <%= step.status === 'completed' ? 'done' : step.status === 'pending' && i === tx.completedSteps ? 'active' : '' %>"
                         title="<%= step.step_name || step.step_code %>"></div>
                    <% }) %>
                <% } %>
            </div>

            <%# Current step info %>
            <% if (tx.currentStepInfo) { %>
            <div style="font-size:12px; color:var(--text-muted); margin-bottom:10px;">
                Current step: <strong style="color:var(--text-main);"><%= tx.currentStepInfo.step_name || tx.currentStepInfo.step_code %></strong>
            </div>
            <% } %>

            <%# OTP notice — show contact link if waiting for admin code %>
            <% if (tx.needsOtp) { %>
            <div class="otp-notice">
                <i class="fa-solid fa-shield-halved" style="margin-top:1px;flex-shrink:0;"></i>
                <div>
                    <strong>Verification code required.</strong> This step needs a code from our support team.
                    If you haven't received it yet, contact support to request your code.
                    <br>
                    <a href="/user/contact-support?tx=<%= tx.id %>&reason=otp" class="contact-btn">
                        <i class="fa-solid fa-headset"></i> Contact Support for Code
                    </a>
                </div>
            </div>
            <% } %>

            <div style="display:flex; gap:10px; margin-top:14px;">
                <a href="/user/withdraw/steps/<%= tx.id %>" class="btn-resume">
                    <i class="fa-solid fa-play"></i> Resume Withdrawal
                </a>
                <button class="btn-cancel" onclick="cancelWithdrawal(<%= tx.id %>)">
                    Cancel
                </button>
            </div>

            <div style="font-size:11px; color:var(--text-muted); margin-top:10px;">
                Started <%= new Date(tx.created_at).toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric', hour:'2-digit', minute:'2-digit'}) %>
            </div>
        </div>
        <% }) %>

    <% } else { %>
    <div class="f-card">
        <div class="empty-state">
            <i class="fa-solid fa-circle-check" style="font-size:48px; color:#22c55e; margin-bottom:16px;"></i>
            <h5 style="font-weight:800;">All Clear!</h5>
            <p>You have no pending withdrawals.</p>
            <a href="/user/withdraw" style="display:inline-block; margin-top:16px; background:#0F6E56; color:white; padding:10px 24px; border-radius:20px; font-weight:700; text-decoration:none;">
                New Withdrawal
            </a>
        </div>
    </div>
    <% } %>

</div>

<nav class="mobile-nav">
    <a href="/user/dashboard"     class="nav-item"><i class="fa-solid fa-house-chimney"></i> Home</a>
    <a href="/user/transactions"  class="nav-item"><i class="fa-solid fa-chart-column"></i> Activity</a>
    <a href="/user/withdraw"      class="nav-item"><i class="fa-solid fa-money-bill-transfer"></i> Transfer</a>
    <a href="/user/profile"       class="nav-item"><i class="fa-solid fa-user-gear"></i> Profile</a>
</nav>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
async function cancelWithdrawal(txId) {
    if (!confirm('Are you sure you want to cancel this withdrawal?')) return;
    try {
        const res = await fetch('/user/withdraw/cancel/' + txId, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
        const data = await res.json();
        if (data.success) {
            window.location.reload();
        } else {
            alert(data.message || 'Failed to cancel');
        }
    } catch (e) {
        window.location.href = '/user/network-error?return=' + encodeURIComponent(window.location.pathname);
    }
}
</script>
</body>
</html>