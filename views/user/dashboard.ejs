<%
  // Use res.locals variables (set by middleware/preferences.js)
  // Fallback to user object if middleware hasn't run
  const _lang   = typeof lang           !== 'undefined' ? lang           : (user?.preferred_language || 'en');
  const _theme  = typeof theme          !== 'undefined' ? theme          : (user?.preferred_theme    || 'light');
  const _symbol = typeof currencySymbol !== 'undefined' ? currencySymbol : '$';
  const _currency = typeof currency     !== 'undefined' ? currency       : 'USD';
%>

<!DOCTYPE html>
<html lang="<%= _lang %>" data-theme="<%= _theme %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Finora Bank</title>

    <%# Apply theme BEFORE any CSS loads — prevents flash of wrong colours %>
    <script>
        document.documentElement.setAttribute('data-theme', '<%= _theme %>');
    </script>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/../../css/user-dashbord.css">

    

    <script>
        document.documentElement.setAttribute('data-theme', '<%= _theme %>');
    </script>
</head>
<body>

<div class="main-content">

    <!-- Flash Messages -->
    <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
        <div class="flash-message flash-success">
            <i class="fas fa-circle-check"></i> <%= success_msg %>
        </div>
    <% } %>
    <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
        <div class="flash-message flash-danger">
            <i class="fas fa-circle-exclamation"></i> <%= error_msg %>
        </div>
    <% } %>

    <!-- Header -->
    <header class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="small text-muted mb-0">Welcome back,</p>
            <h1 class="h4 fw-bold mb-0">
                <%= (typeof user !== 'undefined' && user) ? (user.first_name + ' ' + user.last_name) : 'User' %>
            </h1>
        </div>
        <div class="d-flex gap-2">
            <a href="/user/notifications" class="bg-white p-2 rounded-3 border text-decoration-none">
                <i class="fa-solid fa-bell text-muted"></i>
            </a>
            <a href="/user/settings" class="bg-white p-2 rounded-3 border text-decoration-none">
                <i class="fa-solid fa-sliders text-muted"></i>
            </a>
            <a href="/auth/logout" class="bg-white p-2 rounded-3 border text-decoration-none">
                <i class="fa-solid fa-right-from-bracket text-danger"></i>
            </a>
        </div>
    </header>

    <!-- BALANCE CARD -->
    <div class="balance-card">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <div class="balance-label">Total Balance</div>
                <div class="balance-amount" id="displayBalance">
                    <%= typeof displayBalance !== 'undefined' ? displayBalance : _symbol + (parseFloat(activeAccount?.balance || 0)).toLocaleString('en-US', {minimumFractionDigits: 2}) %>
                </div>
            </div>

            <% if (typeof accounts !== 'undefined' && accounts && accounts.length > 1) { %>
            <div class="dropdown">
                <button class="btn btn-sm text-white border-0"
                        style="background:rgba(255,255,255,0.2);border-radius:12px;padding:8px 14px;"
                        data-bs-toggle="dropdown">
                    <span id="activeAccountName">
                        <%= activeAccount?.account_type?.replace('_',' ') || 'Checking' %>
                    </span>
                    <i class="fa-solid fa-chevron-down ms-1"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <% accounts.forEach(acc => { %>
                    <li>
                        <a class="dropdown-item d-flex justify-content-between align-items-center py-2"
                           href="#"
                           onclick="switchAccount('<%= acc.id %>','<%= acc.account_type %>','<%= acc.displayBalance || _symbol + parseFloat(acc.balance||0).toFixed(2) %>')"
                           style="<%= acc.id === activeAccount?.id ? 'background:#f0fdf8;color:var(--primary);font-weight:700;' : '' %>">
                            <span class="text-capitalize"><%= acc.account_type.replace('_',' ') %></span>
                            <span class="fw-bold"><%= acc.displayBalance || _symbol + parseFloat(acc.balance||0).toLocaleString('en-US', {minimumFractionDigits: 2}) %></span>
                        </a>
                    </li>
                    <% }) %>
                </ul>
            </div>
            <% } %>
        </div>

        <div class="action-buttons" style="grid-template-columns: repeat(3, 1fr);">
        <a href="/user/withdraw"        class="action-btn"><i class="fa-solid fa-money-bill-transfer"></i><span>Withdraw</span></a>
        <a href="/user/deposit"         class="action-btn"><i class="fa-solid fa-wallet"></i><span>Deposit</span></a>
        <!-- <a href="/user/transfer"        class="action-btn"><i class="fa-solid fa-paper-plane"></i><span>Send</span></a> -->
        <a href="/user/kyc-submit"      class="action-btn"><i class="fa-solid fa-shield-halved"></i><span>Verify</span></a>
        <a href="/user/open-account"    class="action-btn"><i class="fa-solid fa-circle-plus"></i><span>Open Acct</span></a>
        <!-- <a href="/user/account-details/<%= account.id %>" class="action-btn">
    <i class="fa-solid fa-file-invoice"></i><span>Details</span>
</a> -->
    </div>
    </div>

    <div class="row g-4">

       

        <!-- Virtual Card -->
        <div class="col-12 col-lg-5">
            <div class="f-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold mb-0">My Virtual Card</h6>
                    <div class="dropdown">
                        <i class="fa-solid fa-ellipsis-vertical text-muted" style="cursor:pointer" data-bs-toggle="dropdown"></i>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/user/card-details">Card Details</a></li>
                            <li><a class="dropdown-item" href="/user/freeze-card">Freeze Card</a></li>
                        </ul>
                    </div>
                </div>
                <div class="visa-card">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="card-chip"></div>
                        <i class="fa-brands fa-cc-visa fs-1"></i>
                    </div>
                    <div class="card-number">
                        **** **** **** <%= (typeof account !== 'undefined' && account && account.account_number) ? account.account_number.slice(-4) : '0000' %>
                    </div>
                    <div class="d-flex justify-content-between align-items-end">
                        <div>
                            <div class="card-holder">Card Holder</div>
                            <div class="fw-bold">
                                <%= (typeof user !== 'undefined' && user) ? (user.first_name + ' ' + user.last_name).toUpperCase() : 'USER' %>
                            </div>
                        </div>
                        <div>
                            <div class="card-holder text-end">Expires</div>
                            <div class="fw-bold">12/28</div>
                        </div>
                    </div>
                </div>
                <div class="mt-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="small text-muted">Weekly Spending Limit</span>
                        <span class="small fw-bold"><%= typeof weeklyLimit !== 'undefined' ? weeklyLimit : _symbol + '5,000.00' %></span>
                    </div>
                    <div class="progress" style="height:6px;border-radius:10px;">
                        <div class="progress-bar" style="width:35%;background:var(--primary);"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Transfer -->
        <div class="col-12 col-lg-7">
            <div class="f-card">
                <h6 class="fw-bold mb-4">Quick Money Transfer</h6>
                <div class="d-flex gap-3 mb-4 flex-wrap">
                    <div class="text-center">
                        <img src="https://ui-avatars.com/api/?name=Mark+R&background=0F6E56&color=fff" class="transfer-user" alt="Mark">
                        <p class="small mt-2 mb-0 fw-bold">Mark</p>
                    </div>
                    <div class="text-center">
                        <img src="https://ui-avatars.com/api/?name=Sarah+L&background=1D9E75&color=fff" class="transfer-user" alt="Sarah">
                        <p class="small mt-2 mb-0 fw-bold">Sarah</p>
                    </div>
                    <div class="text-center">
                        <img src="https://ui-avatars.com/api/?name=Dave+H&background=333&color=fff" class="transfer-user" alt="Dave">
                        <p class="small mt-2 mb-0 fw-bold">Dave</p>
                    </div>
                    <div class="text-center">
                        <div class="transfer-user add-user"><i class="fa-solid fa-plus"></i></div>
                        <p class="small mt-2 mb-0">Add</p>
                    </div>
                </div>
                <form action="/user/transfer" method="POST">
                    <div class="mb-4">
                        <label class="small fw-bold text-muted text-uppercase mb-2">Amount to send</label>
                        <input type="number" name="amount" class="form-control"
                               style="background:var(--bg-input);border:none;border-radius:15px;padding:15px;font-weight:800;font-size:1.2rem;color:var(--primary);text-align:center;"
                               placeholder="0.00" min="0.01" step="0.01" required>
                    </div>
                    <button type="submit" class="btn w-100 py-3 rounded-4 fw-bold"
                            style="background:var(--text-main);color:white;">
                        <i class="fa-solid fa-paper-plane me-2"></i> Send Money
                    </button>
                </form>
            </div>
        </div>

        <!-- Stats Row -->
        <div class="col-12">
            <div class="f-card">
                <div class="row align-items-center">
                    <div class="col-md-4" style="border-right:1px solid var(--border);">
                        <div class="p-2">
                            <span class="text-muted small fw-bold">
                                <i class="fa-solid fa-wallet me-2" style="color:var(--primary);"></i> AVAILABLE BALANCE
                            </span>
                            <div class="h2 fw-bold mt-1 mb-0">
                                <%= typeof displayBalance !== 'undefined' ? displayBalance : _symbol + (parseFloat(account?.balance || 0)).toLocaleString('en-US', {minimumFractionDigits: 2}) %>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4" style="border-right:1px solid var(--border);">
                        <div class="p-2">
                            <span class="text-muted small fw-bold">
                                <i class="fa-solid fa-repeat me-2" style="color:var(--primary);"></i> TOTAL ACTIVITY
                            </span>
                            <div class="h2 fw-bold mt-1 mb-0">
                                <%= (typeof stats !== 'undefined' && stats && stats.total_transactions !== undefined) ? stats.total_transactions : 0 %>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4">
                        <div class="p-2">
                            <span class="text-muted small fw-bold">
                                <i class="fa-solid fa-shield-halved me-2" style="color:var(--primary);"></i> KYC STATUS
                            </span>
                            <div class="mt-1">
                                <% const kycStatusValue = (typeof kyc !== 'undefined' && kyc?.status) ? kyc.status : (user?.kyc_status || 'not_submitted'); %>
                                <% if (kycStatusValue === 'approved') { %>
                                    <span class="kyc-badge kyc-verified"><i class="fa-solid fa-circle-check"></i> Verified</span>
                                <% } else if (kycStatusValue === 'pending') { %>
                                    <span class="kyc-badge kyc-pending"><i class="fa-solid fa-clock"></i> Pending</span>
                                <% } else { %>
                                    <span class="kyc-badge kyc-unverified"><i class="fa-solid fa-circle-xmark"></i> Unverified</span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Transactions -->
        <div class="col-12">
            <div class="f-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h6 class="fw-bold mb-0">Recent Transactions</h6>
                    <a href="/user/transactions" class="small text-decoration-none" style="color:var(--primary);">View All</a>
                </div>

                <% if (typeof transactions !== 'undefined' && transactions && transactions.length > 0) { %>
                    <% transactions.forEach(tx => { %>
                        <div class="transaction-item">
                            <div class="d-flex align-items-center gap-3">
                                <div class="transaction-icon <%= ['deposit','admin_credit'].includes(tx.type) ? 'tx-deposit' : ['withdrawal','admin_debit'].includes(tx.type) ? 'tx-withdrawal' : 'tx-transfer' %>">
                                    <i class="fa-solid <%= ['deposit','admin_credit'].includes(tx.type) ? 'fa-arrow-down' : ['withdrawal','admin_debit'].includes(tx.type) ? 'fa-arrow-up' : 'fa-exchange-alt' %>"></i>
                                </div>
                                <div>
                                    <div class="fw-bold"><%= tx.description || tx.type.replace(/_/g,' ').toUpperCase() %></div>
                                    <div class="small text-muted"><%= new Date(tx.created_at).toLocaleDateString() %></div>
                                </div>
                            </div>
                            <div class="fw-bold <%= ['deposit','admin_credit'].includes(tx.type) ? 'text-success' : ['withdrawal','admin_debit'].includes(tx.type) ? 'text-danger' : '' %>">
                                <%= ['deposit','admin_credit'].includes(tx.type) ? '+' : ['withdrawal','admin_debit'].includes(tx.type) ? '-' : '' %>
                                <%= tx.displayAmount || _symbol + (parseFloat(tx.amount || 0)).toLocaleString('en-US', {minimumFractionDigits: 2}) %>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="text-center py-5 text-muted">
                        <i class="fa-solid fa-receipt fs-1 mb-3"></i>
                        <p>No transactions yet</p>
                    </div>
                <% } %>
            </div>
        </div>

    </div>
</div>

<%- include('../mobile_partier/nav') %>
 <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function switchAccount(id, type, balance) {
        fetch('/user/set-active-account', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ accountId: id })
        }).then(() => location.reload());
    }
</script>

</body>
</html>