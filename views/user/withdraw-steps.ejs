<%
  // ── SAFE LOCALS ──
  const _lang     = typeof lang           !== 'undefined' ? lang           : 'en';
  const _theme    = typeof theme          !== 'undefined' ? theme          : 'light';
  const _symbol   = typeof symbol         !== 'undefined' ? symbol         : '$';
  const _currency = typeof currency       !== 'undefined' ? currency       : 'USD';

  // Use different names to avoid temporal dead zone
  const __currentStep = typeof locals._currentStep !== 'undefined' ? locals._currentStep : (typeof locals.currentStep !== 'undefined' ? locals.currentStep : 1);
  const __totalSteps  = typeof locals._totalSteps  !== 'undefined' ? locals._totalSteps  : (typeof locals.totalSteps  !== 'undefined' ? locals.totalSteps  : 4);
  const __stepConfig  = typeof locals._stepConfig  !== 'undefined' ? locals._stepConfig  : (typeof locals.stepConfig  !== 'undefined' ? locals.stepConfig  : { step_name: 'Step ' + __currentStep, step_code: 'STEP_' + __currentStep, description: '' });
  const __transaction = typeof locals._transaction !== 'undefined' ? locals._transaction : (typeof locals.transaction !== 'undefined' ? locals.transaction : { id: 0, amount: 0, description: '', recipient_account: '', status: 'pending', created_at: new Date() });
  const __stepLogs    = typeof locals._stepLogs    !== 'undefined' ? locals._stepLogs    : (typeof locals.stepLogs    !== 'undefined' ? locals.stepLogs    : []);
  const __validationRules = typeof locals._validationRules !== 'undefined' ? locals._validationRules : (typeof locals.validationRules !== 'undefined' ? locals.validationRules : { requires_document: false, requires_selfie: false, requires_otp: false });
  const __rejectionReasons = typeof locals._rejectionReasons !== 'undefined' ? locals._rejectionReasons : (typeof locals.rejectionReasons !== 'undefined' ? locals.rejectionReasons : []);
  const __formattedAmount = typeof locals._formattedAmount !== 'undefined' ? locals._formattedAmount : (typeof locals.formattedAmount !== 'undefined' ? locals.formattedAmount : _symbol + parseFloat((__transaction.amount || 0)).toFixed(2));
  const __stepNonce = typeof locals._stepNonce !== 'undefined' ? locals._stepNonce : (typeof locals.stepNonce !== 'undefined' ? locals.stepNonce : '');
  
  // Now assign to the names the template uses
  const _currentStep = __currentStep;
  const _totalSteps  = __totalSteps;
  const _stepConfig  = __stepConfig;
  const _transaction = __transaction;
  const _stepLogs    = __stepLogs;
  const _validationRules = __validationRules;
  const _rejectionReasons = __rejectionReasons;
  const _formattedAmount = __formattedAmount;
  const _stepNonce = __stepNonce;
%>

<!DOCTYPE html>
<html lang="<%= _lang %>" data-theme="<%= _theme %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Withdrawal Steps' %> - Finora Bank</title>
    <script>document.documentElement.setAttribute('data-theme', '<%= _theme %>');</script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
     <link rel="stylesheet" href="/../../css/user-withdrawstep.css">
</head>
<body>

<div class="main-content">

    <!-- Header -->
    <div class="header-card">
        <div>
            <div class="mb-1">
                <a href="/user/withdraw" class="text-white text-decoration-none opacity-75" style="font-size:13px;">
                    <i class="fa-solid fa-chevron-left me-1"></i> Back to Withdraw
                </a>
            </div>
            <h1>Withdrawal Verification</h1>
            <p>Complete step <%= _currentStep %> of <%= _totalSteps %> to process your withdrawal</p>
        </div>
    </div>

    <!-- Progress Bar -->
    <div class="progress-line">
        <div class="progress-fill" style="width: <%= (_currentStep / _totalSteps) * 100 %>%"></div>
    </div>

    <!-- Step Header -->
    <div class="step-header">
        <div class="step-number-badge"><%= _currentStep %></div>
        <div class="step-header-info">
            <h2><%= _stepConfig.step_name || 'Verification Step' %></h2>
            <p>Step <%= _currentStep %> of <%= _totalSteps %></p>
        </div>
    </div>

    <!-- Step Badge -->
    <% 
        let badgeClass = '';
        let badgeIcon = 'fa-circle';
        if (_stepConfig.step_code === 'ADMIN_APPROVE') {
            badgeClass = 'admin';
            badgeIcon = 'fa-user-tie';
        } else if (_stepConfig.step_code === 'OTP_CONFIRM') {
            badgeClass = 'otp';
            badgeIcon = 'fa-shield-halved';
        } else if (_stepConfig.step_code === 'KYC_VERIFY') {
            badgeIcon = 'fa-id-card';
        } else if (_stepConfig.step_code === 'TAX_DOC') {
            badgeIcon = 'fa-file-invoice-dollar';
        }
        let badgeText = _stepConfig.step_code ? _stepConfig.step_code.replace(/_/g, ' ') : 'STEP ' + _currentStep;
    %>
    <div class="step-badge <%= badgeClass %>">
        <i class="fa-solid <%= badgeIcon %>"></i>
        <%= badgeText %>
    </div>

    <!-- Main Content -->
    <div class="row g-4">
        <div class="col-12 col-lg-8">

            <!-- Description -->
            <div class="f-card">
                <div class="section-label">
                    <i class="fa-solid fa-circle-info" style="color:var(--primary);"></i>
                    What You Need to Do
                </div>
                <p style="font-size:14px; color:var(--text-muted); line-height:1.6; margin:0;">
                    <%= _stepConfig.description || 'Complete this verification step to proceed with your withdrawal.' %>
                </p>
            </div>

            <!-- Step Action -->
            <div class="f-card">
                <div class="section-label">
                    <i class="fa-solid fa-pen-to-square" style="color:var(--primary);"></i>
                    Complete This Step
                </div>

                <% if (_stepConfig.step_code === 'ADMIN_APPROVE') { %>
                    <!-- Admin Review Waiting State -->
                    <div class="waiting-review">
                        <div class="spinner-ring"></div>
                        <h3>Under Administrative Review</h3>
                        <p>Your withdrawal of <strong><%= _formattedAmount %></strong> is being reviewed by our team.</p>
                        <p style="font-size:12px; margin-top:8px;">This usually takes a few hours. You'll be notified via email.</p>
                        <div style="margin-top:24px;">
                            <a href="/user/dashboard" class="btn-submit btn-submit-green" style="text-decoration:none; display:inline-flex; width:auto; padding:12px 24px;">
                                <i class="fa-solid fa-house me-2"></i> Go to Dashboard
                            </a>
                        </div>
                    </div>

                <% } else { %>
                    <!-- Active Step Form -->
                    <form id="stepForm" 
                          action="/user/withdraw/steps/<%= _transaction.id %>" 
                          method="POST" 
                          enctype="multipart/form-data"
                          data-tx-id="<%= _transaction.id %>">

                        <!-- SECURITY: Step nonce -->
                        <input type="hidden" name="step_nonce" value="<%= _stepNonce %>">

                        <% if (_validationRules && _validationRules.requires_document === true) { %>
                        <div class="mb-4">
                            <label class="form-label">
                                <i class="fa-solid fa-file-arrow-up me-1"></i>
                                Upload Required Document
                            </label>
                            <div class="file-drop" onclick="document.getElementById('documentFile').click()">
                                <i class="fa-solid fa-cloud-arrow-up"></i>
                                <div class="file-drop-text">Click to upload or drag & drop</div>
                                <div class="file-drop-sub">PDF, JPG, PNG (max 10MB)</div>
                            </div>
                            <input type="file" id="documentFile" name="document" accept=".pdf,.jpg,.jpeg,.png" style="display:none;" onchange="handleFileSelect(this)" required>
                            <div id="filePreview" style="margin-top:12px; display:none; padding:12px; background:#f0fdf8; border-radius:10px; border:1px solid #bbf7d0; font-size:13px;">
                                <i class="fa-solid fa-file-circle-check me-1" style="color:var(--success);"></i>
                                <span id="fileName"></span>
                            </div>
                        </div>
                        <% } %>

                        <% if (_validationRules && _validationRules.requires_selfie === true) { %>
                        <div class="mb-4">
                            <label class="form-label">
                                <i class="fa-solid fa-camera me-1"></i>
                                Upload Selfie
                            </label>
                            <div class="file-drop" onclick="document.getElementById('selfieFile').click()">
                                <i class="fa-solid fa-user-circle"></i>
                                <div class="file-drop-text">Take photo or upload selfie</div>
                                <div class="file-drop-sub">Must clearly show your face</div>
                            </div>
                            <input type="file" id="selfieFile" name="selfie" accept="image/*" capture="user" style="display:none;" onchange="handleSelfieSelect(this)" required>
                            <div id="selfiePreview" style="margin-top:12px; display:none;">
                                <img id="selfieImg" style="max-width:200px; border-radius:12px; border:2px solid var(--border);" />
                            </div>
                        </div>
                        <% } %>

                        <% if (_validationRules && _validationRules.requires_otp === true) { %>
                            <div class="mb-4">
                                <label class="form-label">
                                    <i class="fa-solid fa-shield-halved me-1"></i>
                                    Verification Code
                                </label>
                                <input type="text" class="form-control" name="otp_code" id="otpInput" 
                                    placeholder="Enter verification code" maxlength="6" pattern="[0-9]*" 
                                    required style="text-align:center; letter-spacing:12px; font-size:1.5rem; font-weight:800; padding:16px;">
                                <div style="font-size:12px; color:var(--text-muted); margin-top:8px;">
                                    <i class="fa-solid fa-clock me-1"></i>
                                    Enter the code you received
                                </div>
                                
                                <!-- Contact Support Button -->
                                <div style="margin-top:12px; text-align:center;">
                                    <a href="/user/contact-support" 
                                    class="btn-submit btn-outline-primary" 
                                    style="text-decoration:none; display:inline-flex; align-items:center; gap:8px; background:transparent; color:var(--primary); border:2px solid var(--primary); width:auto; padding:10px 20px; font-size:13px; font-weight:600;">
                                        <i class="fa-solid fa-headset"></i>
                                        Contact Support
                                    </a>
                                </div>
                            </div>
                            <% } %>

                        <input type="hidden" name="document_url" id="documentUrl">

                        <div class="mb-4">
                            <label class="form-label">Additional Notes (Optional)</label>
                            <textarea class="form-control" name="stepData" rows="3" placeholder="Any additional information..."></textarea>
                        </div>

                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn-submit btn-submit-green flex-fill" id="submitBtn">
                                <i class="fa-solid fa-check-circle"></i>
                                Complete Step <%= _currentStep %>
                            </button>
                            <button type="button" class="btn-submit btn-outline-danger" style="background:transparent; color:var(--danger); border:2px solid var(--danger); width:auto; padding:16px 24px;" onclick="cancelWithdrawal()">
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </div>
                    </form>
                <% } %>
            </div>

        </div>

        <!-- Sidebar -->
        <div class="col-12 col-lg-4">

            <!-- Transaction Summary -->
            <div class="f-card">
                <div class="section-label">
                    <i class="fa-solid fa-receipt" style="color:var(--primary);"></i>
                    Transaction Details
                </div>
                <div class="info-row">
                    <span class="label">Amount</span>
                    <span class="value" style="color:var(--primary);"><%= _formattedAmount %></span>
                </div>
                <div class="info-row">
                    <span class="label">Status</span>
                    <span class="value">
                        <span style="background:#eff6ff; color:#1e3a8a; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700;">
                            <%= _transaction.status || 'pending' %>
                        </span>
                    </span>
                </div>
                <div class="info-row">
                    <span class="label">To</span>
                    <span class="value"><%= _transaction.recipient_account || '—' %></span>
                </div>
                <div class="info-row">
                    <span class="label">Transaction ID</span>
                    <span class="value" style="font-family:monospace; font-size:12px;">#<%= _transaction.id || '—' %></span>
                </div>
            </div>

            <!-- Step History (Compact) -->
            <% if (_stepLogs && _stepLogs.length > 0) { %>
            <div class="f-card">
                <div class="section-label">
                    <i class="fa-solid fa-list-check" style="color:var(--primary);"></i>
                    Progress
                </div>
                <div style="display:flex; flex-direction:column; gap:8px;">
                    <% _stepLogs.forEach(function(log) { 
                        let logBg = '#f8fafc';
                        let logBorder = '#e2e8f0';
                        let logIconColor = 'var(--text-muted)';
                        let logIcon = 'fa-clock';
                        let logBadgeBg = '#e2e8f0';
                        let logBadgeColor = '#475569';
                        
                        if (log.status === 'completed') {
                            logBg = '#f0fdf4';
                            logBorder = '#bbf7d0';
                            logIconColor = 'var(--success)';
                            logIcon = 'fa-check';
                            logBadgeBg = '#bbf7d0';
                            logBadgeColor = '#064e3b';
                        } else if (log.status === 'rejected') {
                            logBg = '#fef2f2';
                            logBorder = '#fecaca';
                            logIconColor = 'var(--danger)';
                            logIcon = 'fa-xmark';
                            logBadgeBg = '#fecaca';
                            logBadgeColor = '#7f1d1d';
                        }
                        
                        let logCodeText = log.step_code ? log.step_code.replace(/_/g, ' ') : '';
                    %>
                        <div style="display:flex; align-items:center; gap:10px; padding:10px; border-radius:10px; background:<%= logBg %>; border: 1px solid <%= logBorder %>;">
                            <i class="fa-solid <%= logIcon %>" style="color:<%= logIconColor %>; font-size:12px;"></i>
                            <div style="flex:1;">
                                <div style="font-size:12px; font-weight:700;">Step <%= log.step_number %></div>
                                <div style="font-size:11px; color:var(--text-muted);"><%= logCodeText %></div>
                            </div>
                            <span style="font-size:10px; font-weight:700; padding:2px 8px; border-radius:10px; background:<%= logBadgeBg %>; color:<%= logBadgeColor %>;">
                                <%= log.status %>
                            </span>
                        </div>
                    <% }) %>
                </div>
            </div>
            <% } %>

        </div>
    </div>
</div>

<!-- Mobile Nav -->
<nav class="mobile-nav">
    <a href="/user/dashboard" class="nav-item"><i class="fa-solid fa-house-chimney"></i> Home</a>
    <a href="/user/transactions" class="nav-item"><i class="fa-solid fa-chart-column"></i> Activity</a>
    <a href="/user/withdraw" class="nav-item"><i class="fa-solid fa-money-bill-transfer"></i> Transfer</a>
    <a href="/user/profile" class="nav-item"><i class="fa-solid fa-user-gear"></i> Profile</a>
</nav>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    async function cancelWithdrawal() {
        if (!confirm('Cancel this withdrawal?')) return;
        const txId = document.getElementById('stepForm')?.getAttribute('data-tx-id');
        if (!txId) {
            alert('Transaction ID missing');
            return;
        }
        try {
            const response = await fetch('/user/withdraw/cancel/' + txId, {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            const data = await response.json();
            if (data.success) {
                window.location.href = '/user/withdraw';
            } else {
                alert(data.message || 'Failed to cancel');
            }
        } catch (err) {
            alert('Network error');
        }
    }

    function handleFileSelect(input) {
        if (input.files && input.files[0]) {
            document.getElementById('fileName').textContent = input.files[0].name;
            document.getElementById('filePreview').style.display = 'block';
        }
    }

    function handleSelfieSelect(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('selfieImg').src = e.target.result;
                document.getElementById('selfiePreview').style.display = 'block';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    const otpInput = document.getElementById('otpInput');
    if (otpInput) {
        otpInput.addEventListener('input', function() {
            this.value = this.value.replace(/[^0-9]/g, '');
        });
    }

    const stepForm = document.getElementById('stepForm');
    if (stepForm) {
        stepForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-1"></i>Processing…';

            try {
                const formData = new FormData(stepForm);
                const txId = stepForm.getAttribute('data-tx-id');
                if (!txId || txId === '0' || txId === 'undefined' || txId === 'null' || txId === '') {
                    alert('Transaction ID missing. Please refresh the page.');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fa-solid fa-check-circle"></i> Complete Step <%= _currentStep %>';
                    return;
                }

                const actionUrl = '/user/withdraw/steps/' + txId;
                const response = await fetch(actionUrl, {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                const data = await response.json();
                if (data.success) {
                    if (data.redirect) {
                        window.location.href = data.redirect;
                    } else {
                        window.location.reload();
                    }
                } else {
                    alert(data.message || 'Step completion failed');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fa-solid fa-check-circle"></i> Complete Step <%= _currentStep %>';
                }
            // In withdraw-steps.ejs, replace the catch in the submit listener:
            } catch (error) {
                // Check if it's a network error
                if (!navigator.onLine || error.name === 'TypeError') {
                    window.location.href = '/user/network-error?return=' + 
                        encodeURIComponent('/user/withdraw/steps/' + txId);
                } else {
                    alert('Network error. Please try again.');
                }
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-check-circle"></i> Complete Step <%= _currentStep %>';
            }
        });
    }
</script>
</body>
</html>