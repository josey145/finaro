<%
  /* ── Safe defaults if middleware hasn't run ── */
  const _lang     = typeof lang     !== 'undefined' ? lang     : 'en';
  const _theme    = typeof theme    !== 'undefined' ? theme    : 'light';
  const _currency = typeof currency !== 'undefined' ? currency : 'USD';
  const _symbol   = typeof currencySymbol !== 'undefined' ? currencySymbol : '$';
  const _t        = typeof t        !== 'undefined' ? t        : {};
%>
<!DOCTYPE html>

<html lang="<%= _lang %>" data-theme="<%= _theme %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Finora Bank' %> - Finora Bank</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        /* ══════════════════════════════════════════════════
           LIGHT THEME (default)
        ══════════════════════════════════════════════════ */
        :root {
            --primary:    #0F6E56;
            --accent:     #1D9E75;
            --bg-body:    #F4F8F7;
            --bg-card:    #FFFFFF;
            --bg-input:   #F4F8F7;
            --text-main:  #0D1B16;
            --text-muted: #64748B;
            --border:     #E8EFED;
            --danger:     #ef4444;
            --success:    #22c55e;
            --warning:    #f59e0b;
            --nav-bg:     rgba(255,255,255,0.95);
        }

        /* ══════════════════════════════════════════════════
           DARK THEME
        ══════════════════════════════════════════════════ */
        [data-theme="dark"] {
            --bg-body:    #0f172a;
            --bg-card:    #1e293b;
            --bg-input:   #0f172a;
            --text-main:  #f1f5f9;
            --text-muted: #94a3b8;
            --border:     #334155;
            --nav-bg:     rgba(15,23,42,0.97);
        }

        /* ══════════════════════════════════════════════════
           AUTO THEME (follows OS)
        ══════════════════════════════════════════════════ */
        @media (prefers-color-scheme: dark) {
            [data-theme="auto"] {
                --bg-body:    #0f172a;
                --bg-card:    #1e293b;
                --bg-input:   #0f172a;
                --text-main:  #f1f5f9;
                --text-muted: #94a3b8;
                --border:     #334155;
                --nav-bg:     rgba(15,23,42,0.97);
            }
        }

        /* ══════════════════════════════════════════════════
           GLOBAL STYLES (use CSS vars — auto-swap with theme)
        ══════════════════════════════════════════════════ */
        * { margin:0; padding:0; box-sizing:border-box; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background:  var(--bg-body);
            color:       var(--text-main);
            transition:  background .3s, color .3s;
            padding-bottom: 90px;
        }

        /* Cards */
        .f-card {
            background: var(--bg-card);
            border:     1px solid var(--border);
            border-radius: 24px;
            padding: 24px;
            box-shadow: 0 10px 30px -5px rgba(15,110,86,.05);
            height: 100%;
        }

        /* Inputs */
        .form-control, .form-select, .f-input, .f-select {
            background: var(--bg-input) !important;
            border-color: var(--border) !important;
            color: var(--text-main) !important;
        }
        .form-control:focus, .form-select:focus {
            box-shadow: 0 0 0 3px rgba(15,110,86,.15) !important;
            border-color: var(--primary) !important;
        }

        /* Flash messages */
        .flash-message {
            padding:14px 18px; border-radius:12px; margin-bottom:20px;
            font-size:14px; display:flex; align-items:center; gap:10px;
        }
        .flash-danger  { background:#fef2f2; color:var(--danger);  border:1px solid #fecaca; }
        .flash-success { background:#f0fdf4; color:var(--success); border:1px solid #bbf7d0; }

        /* Mobile nav */
        .mobile-nav {
            position:fixed; bottom:0; left:0; width:100%;
            background: var(--nav-bg);
            backdrop-filter: blur(10px);
            border-top: 1px solid var(--border);
            display:flex; justify-content:space-around;
            padding:10px 0 25px; z-index:1000;
        }
        .nav-item {
            text-align:center; color:var(--text-muted);
            text-decoration:none; font-size:10px; font-weight:700;
        }
        .nav-item.active { color:var(--primary); }
        .nav-item i { font-size:20px; margin-bottom:4px; display:block; }

        /* Dark mode text overrides */
        [data-theme="dark"] .text-muted,
        [data-theme="auto"] .text-muted { color: var(--text-muted) !important; }

        [data-theme="dark"] .bg-white,
        [data-theme="auto"] .bg-white { background: var(--bg-card) !important; }

        [data-theme="dark"] .border,
        [data-theme="auto"] .border { border-color: var(--border) !important; }

        [data-theme="dark"] .transaction-item,
        [data-theme="dark"] .user-row,
        [data-theme="dark"] .notif-item {
            background: var(--bg-card) !important;
            border-color: var(--border) !important;
        }

        @media(min-width:992px) {
            body { padding-bottom:0; }
            .mobile-nav { display:none; }
        }
    </style>

    <!-- Store user prefs as JS globals for client-side use -->
    <script>
    window.__FINORA__ = {
        lang:     "<%- _lang %>",
        theme:    "<%- _theme %>",
        currency: "<%- _currency %>",
        symbol:   "<%- JSON.stringify(_symbol) %>"
    };
</script>
</head>
<body>
